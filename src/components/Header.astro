---
import { ChevronDown, Globe2, Mail, Menu, Phone } from '@lucide/astro';
import { assets, brand, mainNav, services, social } from '../data/site';

const areas = [
  { label: 'Asylum', href: '/practice-areas/asylum/' },
  { label: 'Appeals', href: '/practice-areas/appeals/' },
  { label: 'Bond Hearings', href: '/practice-areas/bond-hearings/' },
  { label: 'Citizenship', href: '/practice-areas/citizenship/' },
  {
    label: 'Deportation Defense & Removal Proceedings',
    href: '/practice-areas/deportation-defense-removal-proceedings/',
  },
  {
    label: 'GREEN CARD (PERMANENT RESIDENCE)',
    href: '/practice-areas/green-card-permanent-residence/',
  },
  { label: 'Habeas Corpus', href: '/practice-areas/habeas-corpus/' },
  {
    label: 'Temporary Protected Status (TPS)',
    href: '/practice-areas/temporary-protected-status/',
  },
  { label: 'Visas', href: '/practice-areas/visas/' },
  {
    label: 'Work Visas & Employment Authorization',
    href: '/practice-areas/work-visas-employment-authorization/',
  },
];

const languages = [
  { code: 'en', label: 'EN' },
  { code: 'fr', label: 'FR' },
  { code: 'ht', label: 'HT' },
  { code: 'es', label: 'ES' },
];
---

<header class="site-header">
  <div class="topbar">
    <div class="header-container topbar-inner">
      <div class="top-left">
        <a href={brand.phoneHref}><Phone size={18} /> {brand.phone}</a>
        <a href={`mailto:${brand.email}`}><Mail size={18} /> {brand.email}</a>
      </div>
      <div class="top-right">
        <div class="languages" aria-label="Languages">
          <Globe2 size={17} />
          {languages.map((language) => (
            <button type="button" class="lang-btn" data-lang={language.code}>
              {language.label}
            </button>
          ))}
        </div>
        <div class="topbar-socials" aria-label="Social media">
          <a href={social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-8h2.7l.4-3.2h-3.1V7.7c0-.9.3-1.6 1.6-1.6h1.7V3.2C16.4 3.1 15.5 3 14.5 3c-2.1 0-3.6 1.3-3.6 3.6v3.2H8v3.2h2.9V21h2.6Z"/></svg>
          </a>
          <a href={social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href={social.tiktok} target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true"><path d="M19.6 6.4a5.7 5.7 0 0 1-3.4-1.2 5.7 5.7 0 0 1-1.9-3.2h-3v13.4a2.7 2.7 0 0 1-2.7 2.6 2.7 2.7 0 0 1-2.6-2.7 2.7 2.7 0 0 1 3.4-2.6V9.6a5.8 5.8 0 0 0-6.4 5.8 5.8 5.8 0 0 0 5.8 5.7 5.8 5.8 0 0 0 5.8-5.7V9.1a8.7 8.7 0 0 0 5 1.5V7.6c-.1 0-.1 0 0-1.2Z"/></svg>
          </a>
          <a href={social.google} target="_blank" rel="noopener noreferrer" aria-label="Google Reviews">
            <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true"><path d="M21.8 10.2H12v3.7h5.7c-.5 2.6-2.8 4.5-5.7 4.5-3.3 0-6-2.7-6-6s2.7-6 6-6c1.5 0 2.8.5 3.8 1.4l2.7-2.7C16.8 3.5 14.5 2.5 12 2.5 6.8 2.5 2.5 6.8 2.5 12S6.8 21.5 12 21.5c5.5 0 9.5-3.9 9.5-9.3 0-.6-.1-1.3-.2-2Z"/></svg>
          </a>
        </div>
        <span>Emergency 24/7</span>
      </div>
    </div>
  </div>

  <div id="google_translate_element" aria-hidden="true"></div>

  <div class="nav-bar">
    <div class="header-container nav-inner">
      <a class="brand" href="/" aria-label={`${brand.firmName} home`}>
        <img src={assets.logoMain} alt={`${brand.attorneyName} — ${brand.firmName}`} width="320" height="100" />
      </a>

      <nav class="desktop-nav" aria-label="Primary navigation">
        {mainNav.map((item) => {
          if (item.label === 'Practice Areas') {
            return (
              <div class="nav-dropdown">
                <a href={item.href}>{item.label} <ChevronDown size={13} /></a>
                <div class="dropdown-menu">
                  {areas.map((sub) => <a href={sub.href}>{sub.label}</a>)}
                </div>
              </div>
            );
          }
          if (item.label === 'Emergency Services') {
            return (
              <div class="nav-dropdown">
                <a href={item.href}>{item.label} <ChevronDown size={13} /></a>
                <div class="dropdown-menu">
                  <a href="/emergency-services/ice-detention-help/">ICE Detention Help</a>
                  <a href="/emergency-services/deportation-order/">Deportation Order</a>
                  <a href="/emergency-services/ice-raid-rights/">ICE Raid Rights</a>
                </div>
              </div>
            );
          }
          if (item.label === 'About Us') {
            return (
              <div class="nav-dropdown">
                <a href={item.href}>{item.label} <ChevronDown size={13} /></a>
                <div class="dropdown-menu">
                  <a href="/testimonials/">Testimonials</a>
                  <a href="/news/">News</a>
                </div>
              </div>
            );
          }
          return <a href={item.href}>{item.label}</a>;
        })}
        <a class="whatsapp" href={brand.whatsappHref} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.8-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.7.2-1.2.2-1.4-.1-.2-.3-.3-.6-.4Zm-5.4 7.5h-.1c-1.8 0-3.6-.5-5.1-1.4l-.4-.2-3.8 1 1-3.7-.2-.4c-1-1.6-1.5-3.4-1.5-5.3 0-5.5 4.5-10 10-10 2.7 0 5.2 1 7 2.9 1.9 1.9 2.9 4.4 2.9 7.1 0 5.5-4.5 10-10 10Zm8.5-18.5C18.3 1 15.3 0 12.1 0 5.4 0 0 5.4 0 12c0 2.1.6 4.2 1.6 6.1L0 24l5.9-1.5c1.8 1 3.9 1.5 6.1 1.5h.1c6.6 0 12-5.4 12-12 0-3.2-1.3-6.2-3.5-8.5Z"/>
          </svg>
          WhatsApp
        </a>
      </nav>

      <details class="mobile-menu">
        <summary aria-label="Open menu"><Menu size={24} /></summary>
        <nav aria-label="Mobile navigation">
          {mainNav.map((item) => <a href={item.href}>{item.label}</a>)}
          <a href="/testimonials/" style="padding-left:32px;font-size:0.9rem;opacity:0.8">— Testimonials</a>
          <a href="/news/" style="padding-left:32px;font-size:0.9rem;opacity:0.8">— News</a>
          <a href={brand.whatsappHref}>WhatsApp</a>
        </nav>
      </details>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    color: #ffffff;
    background: rgba(4, 13, 29, 0.88);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .header-container {
    width: min(100% - 48px, 1450px);
    margin-inline: auto;
  }

  .topbar {
    height: 38px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(3, 10, 24, 0.64);
  }

  .topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 38px;
    color: rgba(255, 255, 255, 0.94);
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 500;
    letter-spacing: 0;
  }

  .top-left,
  .top-right,
  .topbar a,
  .topbar span {
    display: inline-flex;
    align-items: center;
  }

  .top-left {
    gap: 42px;
  }

  .top-right {
    gap: 18px;
  }

  .topbar a,
  .topbar span {
    gap: 9px;
    white-space: nowrap;
  }

  .topbar a:hover {
    color: var(--color-gold);
  }

  .nav-bar {
    height: 91px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    background:
      linear-gradient(90deg, rgba(5, 18, 39, 0.94), rgba(5, 18, 39, 0.78)),
      rgba(5, 18, 39, 0.86);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 91px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    line-height: 0;
    color: #ffffff;
  }

  .brand img {
    height: clamp(48px, 5vw, 64px);
    width: auto;
    display: block;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: clamp(18px, 2.35vw, 38px);
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: clamp(0.95rem, 1vw, 1.05rem);
    font-weight: 500;
    letter-spacing: 0;
    min-width: 0;
  }

  .desktop-nav > a:not(.whatsapp),
  .nav-dropdown > a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 91px;
    padding: 0 2px;
    white-space: nowrap;
  }

  .desktop-nav a:hover,
  .nav-dropdown:hover > a,
  .nav-dropdown:focus-within > a {
    color: var(--color-gold);
  }

  .nav-dropdown {
    position: relative;
  }

  .dropdown-menu {
    position: absolute;
    left: 50%;
    top: 82px;
    z-index: 120;
    display: grid;
    width: 270px;
    padding: 10px;
    opacity: 0;
    visibility: hidden;
    transform: translate(-50%, 8px);
    background: rgba(5, 18, 39, 0.96);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.36);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    transition:
      opacity 160ms ease,
      transform 160ms ease,
      visibility 160ms ease;
  }

  .dropdown-menu a {
    padding: 14px 15px;
    color: rgba(255, 255, 255, 0.88);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0;
  }

  .dropdown-menu a:last-child {
    border-bottom: 0;
  }

  .dropdown-menu a:hover {
    color: #ffffff;
    background: rgba(201, 171, 105, 0.14);
  }

  .nav-dropdown:hover .dropdown-menu,
  .nav-dropdown:focus-within .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, 0);
  }

  .topbar-socials {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .topbar-socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.72);
    transition: color 180ms ease;
    min-height: auto;
    gap: 0;
  }

  .topbar-socials a:hover {
    color: var(--color-gold);
  }

  .languages {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: auto;
    color: #ffffff;
    padding-right: 2px;
  }

  .languages a,
  .lang-btn {
    color: rgba(255, 255, 255, 0.9);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.2px;
    padding: 0 2px;
    background: transparent;
    border: 0;
    cursor: pointer;
    transition: color 180ms ease;
  }

  .lang-btn.is-active {
    color: var(--color-gold);
    font-weight: 700;
  }

  .languages a:hover,
  .lang-btn:hover {
    color: var(--color-gold);
  }

  .whatsapp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    width: 132px;
    height: 42px;
    flex: 0 0 132px;
    padding: 0;
    color: #ffffff;
    background: #25d366;
    border-radius: 4px;
    font-size: 0.86rem;
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
    box-shadow: 0 12px 28px rgba(37, 211, 102, 0.22);
  }

  .whatsapp svg {
    flex: 0 0 auto;
  }

  .whatsapp:hover {
    color: #ffffff !important;
    background: #1ebe5d;
  }

  .mobile-menu {
    display: none;
    position: relative;
  }

  .mobile-menu summary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    cursor: pointer;
    list-style: none;
    border: 1px solid rgba(255, 255, 255, 0.16);
  }

  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .mobile-menu nav {
    position: absolute;
    right: 0;
    top: 54px;
    display: grid;
    width: min(88vw, 360px);
    overflow: hidden;
    background: rgba(5, 18, 39, 0.98);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.4);
  }

  .mobile-menu a {
    padding: 16px 18px;
    color: #ffffff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0;
  }

  @media (max-width: 980px) {
    .desktop-nav {
      display: none;
    }

    .mobile-menu {
      display: block;
    }
  }

  @media (max-width: 1280px) {
    .desktop-nav {
      gap: clamp(12px, 1.35vw, 22px);
      font-size: 0.86rem;
    }

    .top-right .languages {
      display: inline-flex !important;
    }

    .whatsapp {
      width: 116px;
      height: 38px;
      flex-basis: 116px;
      font-size: 0.78rem;
      gap: 6px;
    }
  }

  @media (max-width: 1460px) {
    .desktop-nav {
      gap: clamp(12px, 1.4vw, 22px);
      font-size: 0.88rem;
    }

    .whatsapp {
      width: 118px;
      height: 38px;
      flex-basis: 118px;
      font-size: 0.78rem;
    }
  }

  @media (max-width: 1120px) {
    .desktop-nav {
      gap: 12px;
      font-size: 0.82rem;
      font-weight: 500;
    }

    .desktop-nav > a:not(.whatsapp),
    .nav-dropdown > a {
      gap: 4px;
    }

    .whatsapp {
      width: 108px;
      height: 36px;
      flex-basis: 108px;
      font-size: 0.74rem;
    }
  }

  @media (max-width: 640px) {
    .header-container {
      width: min(100% - 28px, 1450px);
    }

    .topbar-inner {
      font-size: 0.82rem;
    }

    .top-left a:nth-child(2),
    .top-right span,
    .topbar-socials {
      display: none;
    }

    .nav-bar,
    .nav-inner {
      height: 76px;
    }

    .brand img {
      height: 42px;
    }
  }

  #google_translate_element {
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
    visibility: hidden;
  }
</style>

<style is:global>
  .goog-te-banner-frame,
  .skiptranslate {
    display: none !important;
  }

  body {
    top: 0 !important;
  }

  .goog-tooltip,
  .goog-tooltip:hover,
  .goog-text-highlight {
    background: transparent !important;
    box-shadow: none !important;
    border: none !important;
  }
</style>

<script is:inline>
  (function () {
    function getCookie(name) {
      const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
      return match ? decodeURIComponent(match[2]) : null;
    }

    function setCookie(name, value) {
      const host = location.hostname;
      const domain = host.split('.').slice(-2).join('.');
      document.cookie = name + '=' + value + ';path=/;';
      if (host !== 'localhost' && host.indexOf('.') !== -1) {
        document.cookie = name + '=' + value + ';path=/;domain=.' + domain + ';';
      }
    }

    function currentLang() {
      const cookie = getCookie('googtrans');
      if (!cookie) return 'en';
      const parts = cookie.split('/');
      return parts[2] || 'en';
    }

    function markActive() {
      const active = currentLang();
      document.querySelectorAll('.lang-btn').forEach(function (btn) {
        if (btn.dataset.lang === active) btn.classList.add('is-active');
        else btn.classList.remove('is-active');
      });
    }

    function bindButtons() {
      document.querySelectorAll('.lang-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          const lang = btn.dataset.lang;
          if (lang === 'en') {
            setCookie('googtrans', '');
          } else {
            setCookie('googtrans', '/en/' + lang);
          }
          location.reload();
        });
      });
    }

    window.googleTranslateElementInit = function () {
      new google.translate.TranslateElement(
        {
          pageLanguage: 'en',
          includedLanguages: 'en,fr,ht,es',
          autoDisplay: false,
        },
        'google_translate_element'
      );
    };

    function loadTranslate() {
      if (document.getElementById('gtranslate-script')) return;
      const s = document.createElement('script');
      s.id = 'gtranslate-script';
      s.src = 'https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit';
      s.async = true;
      document.body.appendChild(s);
    }

    document.addEventListener('DOMContentLoaded', function () {
      bindButtons();
      markActive();
      loadTranslate();
    });
  })();
</script>
