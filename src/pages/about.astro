---
import BaseLayout from '../layouts/BaseLayout.astro';
import { assets, brand } from '../data/site';
---

<BaseLayout title={`About ${brand.attorneyName} | ${brand.firmName}`}>
  <section class="section section-dark page-hero">
    <div class="container about-hero">
      <div class="section-title">
        <p class="eyebrow">About</p>
        <h1>{brand.attorneyName}</h1>
        <p>Immigration attorney, son of Haitian immigrants, and advocate for families navigating the U.S. immigration system.</p>
      </div>
      <img src={assets.aboutPhoto} alt={brand.attorneyName} />
    </div>
  </section>
  <section class="prose-page watermark-section">
    <div class="container">
      <h2>Experienced and ready to help</h2>
      <p>
        Calvin Pierre is the proud son of Haitian immigrants and a first-generation
        American. The final copy should expand his attorney biography, admissions,
        languages, personal story, community involvement, and firm mission.
      </p>
      <p>
        Keep this page human and specific. For attorney SEO, the biography
        supports trust, local relevance, and conversion across practice pages.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 380px;
    gap: 44px;
    align-items: center;
  }

  .about-hero img {
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 0;
    object-fit: cover;
  }

  @media (max-width: 820px) {
    .about-hero {
      grid-template-columns: 1fr;
    }
  }
</style>
