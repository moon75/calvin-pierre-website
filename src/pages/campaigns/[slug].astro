---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { brand, campaignPages } from '../../data/site';

export function getStaticPaths() {
  return campaignPages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
---

<BaseLayout
  title={`${page.title} | ${brand.firmName}`}
  description={`${page.service}. Campaign-ready landing page for ${brand.firmName}.`}
>
  <section class="campaign section-dark page-hero">
    <div class="container campaign-grid">
      <div class="section-title">
        <p class="eyebrow">Campaign Landing Page</p>
        <h1>{page.title}</h1>
        <p>{page.service}. Speak with an immigration attorney about your next step.</p>
        <div class="actions">
          <a class="btn btn-primary" href={brand.phoneHref}>Call {brand.phone}</a>
          <a class="btn btn-secondary" href="#consultation">Start Intake</a>
        </div>
      </div>
      <div class="conversion-box">
        <span>{brand.rating}</span>
        <span>Confidential case review</span>
        <span>Newark office / nationwide immigration representation</span>
        <span>Languages: {brand.languages.join(', ')}</span>
      </div>
    </div>
  </section>
  <section class="section section-soft watermark-section">
    <div class="container grid grid-3">
      <article class="card mini"><strong>Fast Contact</strong><p>Phone, SMS, WhatsApp, and form tracking can be wired per campaign.</p></article>
      <article class="card mini"><strong>SEO Ready</strong><p>Unique title, description, canonical URL, sitemap inclusion, and service copy.</p></article>
      <article class="card mini"><strong>Ad Ready</strong><p>Designed for Google Ads, Meta ads, and call conversion tracking.</p></article>
    </div>
  </section>
</BaseLayout>

<style>
  .campaign {
    padding: 92px 0;
  }

  .campaign-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 420px;
    gap: 46px;
    align-items: center;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .conversion-box {
    display: grid;
    gap: 12px;
    padding: 24px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 0;
    background: rgba(255, 255, 255, 0.08);
  }

  .conversion-box span,
  .mini {
    padding: 18px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.08);
  }

  .mini p {
    margin-bottom: 0;
    color: #555555;
  }

  @media (max-width: 860px) {
    .campaign-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
