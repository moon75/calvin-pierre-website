---
import {
  ArrowRight,
  ChevronDown,
  FileText,
  Gavel,
  MapPin,
  MessageCircle,
  MessageSquare,
  Phone,
  Plus,
  Quote,
  ShieldCheck,
  ShieldOff,
  Star,
  Unlock,
  UserX,
} from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { brand } from '../../data/site';

const steps = [
  {
    title: 'DO NOT Let Them Sign Anything',
    text: 'Especially "Voluntary Departure" or "Stipulated Removal." These documents waive their right to fight the case. They need a lawyer first.',
  },
  {
    title: 'Find Out Where They Are',
    text: "Check the ICE detainee locator system at locator.ice.gov. You'll need their Alien number and country of birth. In New Jersey, they may be at the Elizabeth Detention Center (EDC) or Delaney Hall initially, but check if they have been transferred to Moshannon Valley (PA) or Batavia (NY).",
  },
  {
    title: 'Gather Their Documents',
    text: "Birth certificates, marriage certificates, proof of U.S. ties (bills, leases, children's school records). We'll need these for the bond hearing.",
  },
  {
    title: 'Do NOT Talk To ICE Without A Lawyer Present',
    text: 'Anything your family member says can be used against them in court.',
  },
  {
    title: 'Contact Us Immediately',
    text: 'The first 48-72 hours are critical for preparing a strong bond case.',
  },
];

const strategies = [
  {
    title: 'Immediate Release Strategy',
    text: "We don't wait. We immediately analyze if your loved one is eligible for a Bond Hearing before a judge or ICE Parole. We gather evidence of community ties, family relationships, and employment history to prove they are not a flight risk.",
    Icon: Unlock,
  },
  {
    title: 'Aggressive Court Representation',
    text: 'We know what Immigration Judges in Newark and the Elizabeth Detention Center look for. Whether your loved one is held locally or transferred to Pennsylvania or New York, we come prepared with documentation that makes the strongest case possible.',
    Icon: Gavel,
  },
  {
    title: 'Deportation Defense Strategy',
    text: "While fighting for their release, we're already building their defense against deportation. Whether it's asylum, cancellation of removal, adjustment of status, or another form of relief — we identify every possible path to let them stay.",
    Icon: ShieldCheck,
  },
  {
    title: 'Family Communication & Support',
    text: "We keep you updated every step of the way. Direct access to our legal team through WhatsApp, and we explain everything in plain language — no legal jargon. Your family member won't face this alone.",
    Icon: MessageSquare,
  },
];

const trustBand = [
  {
    title: '24/7 Emergency Intake',
    text: 'We answer calls and WhatsApp messages around the clock. The first 48-72 hours after detention are critical, and we move as fast as the system allows.',
    Icon: Phone,
  },
  {
    title: 'Multilingual Legal Team',
    text: 'Our team speaks English, Spanish, Portuguese, Haitian Creole, and French — so your family member is heard and understood from day one.',
    Icon: MessageSquare,
  },
  {
    title: '250+ Families Released',
    text: "We've helped over 250 families this year alone secure bond hearings and release from ICE detention across NJ, PA, and NY facilities.",
    Icon: ShieldCheck,
  },
];

const stories = [
  {
    title: 'Released On Bond In 10 Days',
    name: 'Maria S.',
    city: 'Newark, NJ',
    stars: 5,
    text: "My husband was detained at a traffic stop. Attorney Pierre got him released on bond in 10 days. Now we're fighting his case together as a family. I don't know what we would have done without this team.",
  },
  {
    title: 'Released Day After Bond Hearing',
    name: 'Carlos M.',
    city: 'Elizabeth, NJ',
    stars: 5,
    text: "I was detained for 3 weeks before my family found Attorney Pierre. He fought for me at my bond hearing and I was released the next day. He's still helping me with my green card application.",
  },
  {
    title: 'WhatsApp Reply At 11pm Sunday',
    name: 'Ana R.',
    city: 'Harrison, NJ',
    stars: 5,
    text: 'They answered my WhatsApp message at 11pm on a Sunday. By Monday morning, they had already spoken to my wife in detention and filed the paperwork for her bond hearing. We got her out in less than 2 weeks.',
  },
];

const iceFaqs = [
  {
    question: 'How much does this cost?',
    answer: "We understand this is an emergency. We offer payment plans for families facing ICE detention. During your free consultation, we'll discuss your options and create a plan that works for your budget.",
  },
  {
    question: 'How long does it take to get them released?',
    answer: 'It depends on the case. Some clients are released on bond within 7-10 days. Others may take 2-4 weeks depending on the court schedule and the strength of the case. We move as fast as the system allows.',
  },
  {
    question: "What if they've been ordered deported before?",
    answer: "That makes the case more challenging, but not impossible. We've successfully secured bond for clients with prior deportation orders. An old order doesn't automatically mean they can't be released — we analyze every case individually.",
  },
  {
    question: 'Can they be deported while in detention?',
    answer: "Yes, if they have a final deportation order and no pending cases. That's why time is critical. We can file emergency motions to stop deportation and keep fighting their case. But we need to act fast.",
  },
  {
    question: "What are the chances they'll be released?",
    answer: "Every case is different. Factors include: criminal history, prior immigration violations, family ties in the U.S., length of time in the country, and employment history. During your consultation, we'll honestly assess their situation and fight for the best possible outcome.",
  },
];
---

<BaseLayout
  title={`ICE Detention Help | 24/7 Emergency Immigration Lawyer | ${brand.firmName}`}
  description="Your family member was detained by ICE? Attorney Calvin Pierre fights for their release. 24/7 emergency intake for bond hearings, parole, and deportation defense."
>
  <section class="section section-dark page-hero ice-hero">
    <div class="container ice-hero-grid">
      <div class="ice-hero-copy">
        <span class="hero-eyebrow">
          <Gavel size={16} stroke-width={1.8} />
          Emergency Service · 24/7 Intake
          <Gavel size={16} stroke-width={1.8} />
        </span>
        <h1>Your Family Member Was Detained By ICE. We Fight For Their Release Starting Today.</h1>
        <p>
          As a proud son of Haitian immigrants, Attorney Calvin Pierre understands what your family
          is going through. We speak English, Spanish, Portuguese, Haitian Creole, and French.
        </p>
        <div class="ice-hero-actions">
          <a class="btn btn-primary" href={brand.phoneHref}>
            <Phone size={16} stroke-width={2} />
            Call {brand.phone}
          </a>
          <a class="btn btn-whatsapp" href={brand.whatsappHref} target="_blank" rel="noopener">
            <MessageCircle size={16} stroke-width={2} />
            WhatsApp Now
          </a>
        </div>
        <p class="ice-hero-trust">
          <ShieldCheck size={15} stroke-width={2} />
          We've helped 250+ families secure bond and release from ICE detention this year.
        </p>
      </div>
    </div>
  </section>

  <section class="support-band section-soft watermark-section">
    <div class="container support-grid">
      {trustBand.map(({ title, text, Icon }) => (
        <article class="support-item">
          <div class="support-icon"><Icon size={32} stroke-width={1.55} /></div>
          <div>
            <h2>{title}</h2>
            <p>{text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section ice-steps-section watermark-section">
    <div class="container ice-steps-grid">
      <div class="ice-steps-intro">
        <span class="hero-eyebrow">
          <Gavel size={16} stroke-width={1.8} />
          What To Do Right Now
          <Gavel size={16} stroke-width={1.8} />
        </span>
        <h2>The first hours matter. Follow these steps immediately.</h2>
        <p>
          If your loved one was just detained by ICE, these are the actions our team will guide
          you through within minutes of your first call.
        </p>
        <a class="btn btn-outline" href={brand.phoneHref}>
          Start Emergency Intake
          <ArrowRight size={16} stroke-width={1.8} />
        </a>
      </div>
      <ol class="ice-step-list">
        {steps.map((step, index) => (
          <li class="ice-step">
            <span class="ice-step-num">{String(index + 1).padStart(2, '0')}</span>
            <div class="ice-step-body">
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section ice-strategies-section">
    <div class="container">
      <div class="ice-section-head">
        <span class="hero-eyebrow">
          <Gavel size={16} stroke-width={1.8} />
          Our Approach
          <Gavel size={16} stroke-width={1.8} />
        </span>
        <h2>How we fight for your family member</h2>
        <p>
          Four parallel strategies, executed from day one — built to maximize release time and
          protect their long-term path to stay in the United States.
        </p>
      </div>
      <div class="ice-strategy-grid">
        {strategies.map(({ title, text, Icon }) => (
          <article class="ice-strategy-card">
            <span class="ice-strategy-icon"><Icon size={28} stroke-width={1.5} /></span>
            <h3>{title}</h3>
            <p>{text}</p>
            <ArrowRight class="ice-strategy-arrow" size={15} />
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section ice-stories-section">
    <div class="container">
      <div class="ice-section-head">
        <span class="hero-eyebrow">
          <Gavel size={16} stroke-width={1.8} />
          Real Results
          <Gavel size={16} stroke-width={1.8} />
        </span>
        <h2>Families We've Helped</h2>
      </div>
      <div class="ice-stories-grid">
        {stories.map((story) => (
          <article class="ice-story-card">
            <Quote class="ice-story-quote" size={36} stroke-width={1.4} />
            <div class="ice-story-stars" aria-label={`${story.stars} out of 5 stars`}>
              {Array.from({ length: 5 }, (_, i) =>
                i < story.stars ? (
                  <Star size={16} fill="currentColor" stroke-width={0} />
                ) : (
                  <Star size={16} stroke-width={1.6} />
                )
              )}
            </div>
            <h3 class="ice-story-title">"{story.title}"</h3>
            <p>{story.text}</p>
            <footer>
              <strong>{story.name}</strong>
              <span>{story.city}</span>
            </footer>
          </article>
        ))}
      </div>
      <p class="ice-disclaimer">
        Past results do not guarantee a future outcome. Every case is different.
      </p>
    </div>
  </section>

  <section class="section ice-faq-section">
    <div class="container ice-faq-grid">
      <div class="ice-faq-copy">
        <span class="hero-eyebrow">
          <Gavel size={16} stroke-width={1.8} />
          FAQ
          <Gavel size={16} stroke-width={1.8} />
        </span>
        <h2>Your questions, answered.</h2>
        <p>
          Honest answers about cost, timing, prior orders, and the realistic chances of release.
        </p>
      </div>
      <div class="ice-faq-list">
        {iceFaqs.map((faq, index) => (
          <details class="faq-item" name="ice-faq" open={index === 0}>
            <summary>
              <span class="faq-q-num">{String(index + 1).padStart(2, '0')}</span>
              <span class="faq-q-text">{faq.question}</span>
              <span class="faq-q-icon" aria-hidden="true">
                <Plus size={20} stroke-width={1.75} />
              </span>
            </summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section ice-final-cta watermark-section">
    <div class="container">
      <div class="ice-final-inner">
        <h2>Don't Wait &mdash; Every Hour Matters</h2>
        <p class="ice-final-lead">
          The first hearing often determines if they stay detained for months. We need to prepare now.
        </p>
        <div class="ice-hero-actions ice-final-actions">
          <a class="btn btn-whatsapp" href={brand.whatsappHref} target="_blank" rel="noopener">
            <MessageCircle size={16} stroke-width={2} />
            Emergency Help on WhatsApp
          </a>
          <a class="btn btn-primary" href={brand.phoneHref}>
            <Phone size={16} stroke-width={2} />
            Call Now: Emergency Line
          </a>
        </div>
        <p class="ice-final-languages">
          Hablamos Español &nbsp;|&nbsp; Falamos Português &nbsp;|&nbsp; Nou pale Kreyòl &nbsp;|&nbsp; Nous parlons Français
        </p>
        <div class="ice-final-divider" aria-hidden="true"></div>
        <p class="ice-final-locations">
          <MapPin size={16} stroke-width={2} />
          Office Locations: Headquartered in Newark &nbsp;|&nbsp; Serving All NJ &amp; PA Detention Centers
        </p>
        <p class="ice-final-note">
          Attorney Calvin Pierre is licensed to practice immigration law throughout the United States.
          Immigration cases are federal matters and can be handled from any of our offices.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-eyebrow {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    padding: 8px 16px;
    color: var(--color-gold);
    background: rgba(201, 171, 105, 0.1);
    border: 1px solid rgba(201, 171, 105, 0.4);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.4px;
  }

  .hero-eyebrow svg {
    flex: 0 0 auto;
  }

  .support-band {
    position: relative;
    z-index: 2;
    color: #ffffff;
    overflow: hidden;
    background: linear-gradient(180deg, #04102a 0%, #061227 100%);
  }

  .support-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(18px, 2vw, 28px);
    padding: 40px 0 38px;
  }

  .support-item {
    position: relative;
    display: grid;
    grid-template-columns: 50px minmax(0, 1fr);
    gap: 18px;
    align-content: start;
    min-height: 188px;
    padding: 28px 26px 24px;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.02)),
      rgba(8, 24, 56, 0.55);
    border: 1px solid rgba(201, 171, 105, 0.2);
    transition: transform 180ms ease, border-color 180ms ease;
  }

  .support-item::before {
    position: absolute;
    inset: 0 0 auto;
    height: 4px;
    content: "";
    background: linear-gradient(90deg, var(--color-gold), rgba(8, 38, 88, 0.34));
  }

  .support-item::after {
    position: absolute;
    right: -42px;
    bottom: -52px;
    width: 150px;
    height: 150px;
    content: "";
    border-radius: 999px;
    background: rgba(201, 171, 105, 0.08);
  }

  .support-item:hover {
    transform: translateY(-4px);
    border-color: rgba(201, 171, 105, 0.34);
  }

  .support-icon {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    aspect-ratio: 1;
    color: var(--color-gold);
    background: rgba(201, 171, 105, 0.14);
    border: 1px solid rgba(201, 171, 105, 0.36);
    border-radius: 50%;
  }

  .support-item h2 {
    position: relative;
    z-index: 1;
    margin: 0 0 12px;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(1.22rem, 1.45vw, 1.52rem);
    font-weight: 700;
    line-height: 1.08;
  }

  .support-item p {
    position: relative;
    z-index: 1;
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.58;
  }

  @media (max-width: 900px) {
    .support-grid {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 42px 0;
    }
  }

  .ice-hero {
    color: #ffffff;
  }

  .ice-hero-grid {
    display: grid;
    gap: 28px;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .ice-hero-copy .hero-eyebrow {
    align-self: center;
    margin: 0 auto 22px;
  }

  .ice-hero-copy h1 {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(2.05rem, 3.8vw, 3.4rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: 0.4px;
    text-transform: uppercase;
  }

  .ice-hero-copy > p {
    max-width: 720px;
    margin: 22px auto 32px;
    color: rgba(255, 255, 255, 0.78);
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.2vw, 1.12rem);
    line-height: 1.6;
  }

  .ice-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
  }

  .ice-hero-actions .btn {
    gap: 10px;
    min-width: 220px;
    min-height: 56px;
    justify-content: center;
    font-size: 0.88rem;
  }

  .btn-whatsapp {
    background: #1faa5a;
    color: #ffffff;
    border: 0;
  }

  .btn-whatsapp:hover {
    background: #178d4a;
    color: #ffffff;
  }

  .ice-hero-trust {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    justify-content: center;
    max-width: 640px;
    margin: 30px auto 0;
    padding: 12px 22px;
    background: rgba(201, 171, 105, 0.1);
    border: 1px solid rgba(201, 171, 105, 0.34);
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.86);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-style: italic;
  }

  .ice-hero-trust svg {
    flex: 0 0 auto;
    color: var(--color-gold);
  }

  .ice-steps-section {
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 18%, rgba(201, 171, 105, 0.1), transparent 32%),
      linear-gradient(180deg, #061227 0%, #04102a 100%);
  }

  .ice-steps-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(48px, 6vw, 100px);
    align-items: start;
  }

  .ice-steps-intro {
    position: sticky;
    top: 130px;
    display: grid;
    gap: 22px;
    align-content: start;
  }

  .ice-steps-intro .hero-eyebrow {
    align-self: start;
    margin: 0;
  }

  .ice-steps-intro h2 {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(1.85rem, 3vw, 2.85rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: 0.4px;
    text-transform: uppercase;
  }

  .ice-steps-intro p {
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.98rem;
    line-height: 1.7;
  }

  .ice-steps-intro .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    align-self: start;
    margin-top: 8px;
    padding: 16px 26px;
    color: #ffffff;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.32);
    border-radius: 4px;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    transition: background 200ms ease, border-color 200ms ease, color 200ms ease;
  }

  .ice-steps-intro .btn-outline:hover {
    color: #0a1f44;
    background: var(--color-gold);
    border-color: var(--color-gold);
  }

  .ice-step-list {
    position: relative;
    margin: 0;
    padding: 4px 0 0;
    list-style: none;
  }

  .ice-step-list::before {
    position: absolute;
    top: 44px;
    bottom: 44px;
    left: 21px;
    width: 0;
    content: "";
    border-left: 2px dotted rgba(255, 255, 255, 0.22);
  }

  .ice-step {
    position: relative;
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr);
    gap: 28px;
    padding: 0 0 36px;
  }

  .ice-step:last-child {
    padding-bottom: 0;
  }

  .ice-step-num {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    background: var(--color-gold);
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: 0.86rem;
    font-weight: 700;
    box-shadow: 0 14px 28px rgba(201, 171, 105, 0.32);
  }

  .ice-step-body h3 {
    margin: 0 0 12px;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 1.6vw, 1.5rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .ice-step-body p {
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    line-height: 1.72;
  }

  .ice-strategies-section {
    color: #ffffff;
    background:
      radial-gradient(circle at 82% 14%, rgba(201, 171, 105, 0.1), transparent 32%),
      linear-gradient(180deg, #04102a 0%, #061227 100%);
  }

  .ice-section-head {
    display: grid;
    gap: 16px;
    justify-items: center;
    max-width: 720px;
    margin: 0 auto 50px;
    text-align: center;
  }

  .ice-section-head h2 {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(1.95rem, 3.4vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: 0.3px;
    text-transform: uppercase;
  }

  .ice-section-head p {
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 1rem;
    line-height: 1.65;
  }

  .ice-strategy-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  .ice-strategy-card {
    position: relative;
    display: grid;
    gap: 16px;
    align-content: start;
    padding: 30px 28px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    transition: background 220ms ease, border-color 220ms ease, transform 220ms ease;
  }

  .ice-strategy-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(201, 171, 105, 0.4);
    transform: translateY(-3px);
  }

  .ice-strategy-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background: var(--color-gold);
    color: #0a1f44;
    border-radius: 4px;
  }

  .ice-strategy-card h3 {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: 1.32rem;
    line-height: 1.25;
  }

  .ice-strategy-card p {
    margin: 0;
    color: rgba(255, 255, 255, 0.66);
    font-size: 0.94rem;
    line-height: 1.65;
  }

  .ice-strategy-arrow {
    color: var(--color-gold);
  }

  .ice-stories-section {
    color: #ffffff;
