---
import {
  AlertTriangle,
  ArrowRight,
  BookOpen,
  FileDown,
  Gavel,
  MapPin,
  MessageCircle,
  MessageSquare,
  Phone,
  Plus,
  Quote,
  Scale,
  ShieldCheck,
  ShieldOff,
  Star,
  UserX,
} from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { brand } from '../../data/site';

const steps = [
  {
    title: 'DO NOT Open The Door',
    text: 'Ask them to slide any warrant under the door. An "ICE warrant" or "administrative warrant" is NOT a judicial warrant signed by a judge — you are not legally required to open your door. Only a judicial warrant (signed by a judge with your name and address) gives them the right to enter.',
  },
  {
    title: 'You Have The Right To Remain Silent',
    text: 'Do NOT answer questions about where you were born, your immigration status, or how you entered the country. Say clearly and calmly: "I am exercising my right to remain silent. I want to speak to my lawyer." You do not have to say anything else.',
  },
  {
    title: 'DO NOT Sign Anything',
    text: 'ICE agents may pressure you to sign documents quickly. Do not sign anything — especially "Voluntary Departure" or "Stipulated Removal" forms — without speaking to a lawyer first. Signing can permanently waive your right to fight your case.',
  },
  {
    title: 'DO NOT Run Or Physically Resist',
    text: 'Stay calm. If agents force entry, do not run or physically resist — this can lead to criminal charges that will seriously hurt your immigration case. Keep repeating: "I am exercising my right to remain silent. I want my lawyer."',
  },
  {
    title: 'Contact Us Immediately',
    text: "Call or WhatsApp us the moment you can. If a family member is arrested, do not wait. The first hours after an ICE raid are the most critical for protecting their rights, preventing deportation, and preparing an emergency legal response.",
  },
];

const strategies = [
  {
    title: 'Immediate Legal Intervention',
    text: "The moment you contact us during an ICE enforcement action, if you're being represented, we get on the phone with ICE agents to assert your rights on the record. If you've already been arrested, we immediately begin detention defense and bond proceedings.",
    Icon: ShieldOff,
  },
  {
    title: 'Constitutional Rights Protection',
    text: "ICE must follow the Constitution. If agents violated your Fourth Amendment rights (illegal search and seizure) or your Fifth Amendment rights (right to remain silent and due process), we document everything and challenge the arrest in court. Rights violations can be the foundation of a strong defense.",
    Icon: Scale,
  },
  {
    title: 'Workplace Raid Defense',
    text: "If ICE enters your workplace, both employees and employers have rights. We represent workers who were detained during I-9 audits or enforcement actions, challenge illegal arrests, and work with employers to understand their legal obligations and protect their workforce.",
    Icon: UserX,
  },
  {
    title: 'Community Education & Preparedness',
    text: "We help families, churches, and community organizations understand their rights before a raid happens. We distribute \"Know Your Rights\" cards, create emergency family plans, and hold preparedness workshops — because the best protection is preparation.",
    Icon: BookOpen,
  },
];

const trustBand = [
  {
    title: '24/7 Emergency Intake',
    text: 'We answer calls and WhatsApp messages around the clock. If ICE is at your door right now, call us before you open it.',
    Icon: Phone,
  },
  {
    title: 'Constitutional Rights Defense',
    text: 'Attorney Calvin Pierre fights every Fourth and Fifth Amendment violation. Illegal arrests and unlawful searches can be the foundation of a winning case.',
    Icon: ShieldCheck,
  },
  {
    title: 'Multilingual Legal Team',
    text: 'Our team speaks English, Spanish, Haitian Creole, and French — so your family is heard and protected from day one.',
    Icon: MessageSquare,
  },
];

const stories = [
  {
    title: 'Rights Asserted — Charges Dropped',
    name: 'Beatrice L.',
    city: 'Newark, NJ',
    stars: 5,
    text: "ICE came to our door at 6am. I remembered my rights card and did not open the door. I called Attorney Pierre immediately. He was on the phone with agents within 20 minutes and my husband was never arrested. Knowing your rights saved our family.",
  },
  {
    title: 'Workplace Raid — Released Same Day',
    name: 'Santos M.',
    city: 'Elizabeth, NJ',
    stars: 5,
    text: "I was detained at my job during an ICE audit. My coworker called Attorney Pierre. By the time they processed me at the facility, his team had already filed paperwork. I was released the same evening. I don't know what I would have done without them.",
  },
  {
    title: 'Unconstitutional Entry — Case Dismissed',
    name: 'Ana P.',
    city: 'Paterson, NJ',
    stars: 5,
    text: "ICE entered my home without a proper warrant. Attorney Pierre filed a motion challenging the entry as unconstitutional. The judge agreed and all charges based on that arrest were dismissed. I still have my green card application pending — and hope.",
  },
];

const iceFaqs = [
  {
    question: 'Do I have to open the door if ICE knocks?',
    answer: "No. You are not required to open your door unless ICE has a judicial warrant — signed by a judge, with your correct name and address. An administrative ICE warrant does not give them the right to enter. Ask them to slide any warrant under the door before opening.",
  },
  {
    question: 'What if ICE forces their way in anyway?',
    answer: "Do not physically resist. Stay calm and keep repeating: \"I am exercising my right to remain silent. I want my lawyer.\" Document everything you can remember — what was said, who was there, what time it happened. Unlawful entry can be challenged in court and may become the basis of your defense.",
  },
  {
    question: 'Can ICE arrest me at work?',
    answer: "Yes. ICE conducts workplace enforcement actions and I-9 audits. If this happens, you still have the right to remain silent and the right to refuse to sign anything without a lawyer. Call us immediately. We work with both employees and employers during workplace enforcement actions.",
  },
  {
    question: 'What if I\'m arrested during a raid?',
    answer: "Do not answer any questions without a lawyer. Remain calm, do not sign anything, and ask for an attorney immediately. Have a trusted family member or friend call our office right away. The first hours after arrest are critical for preparing your bond hearing and defense strategy.",
  },
  {
    question: 'Should I carry a "know your rights" card?',
    answer: 'Yes. A know your rights card gives you clear, simple instructions to follow during an enforcement action — especially when you are scared and under pressure. Download ours below in your language and keep a copy in your home, car, and workplace.',
  },
  {
    question: 'What if I have U.S. citizen children at home?',
    answer: "Make a family preparedness plan now — before a raid happens. Designate a trusted adult to care for your children if you are detained. Keep copies of birth certificates and emergency contact information in a safe place. We can help you create this plan during your consultation.",
  },
];

const rightsCards = [
  { label: 'English', lang: 'en' },
  { label: 'Español', lang: 'es' },
  { label: 'Português', lang: 'pt' },
  { label: 'Kreyòl', lang: 'ht' },
];
---

<BaseLayout
  title={`ICE Raid Rights | Know Your Rights | 24/7 Emergency Help | ${brand.firmName}`}
  description="ICE at your door or workplace? Know your rights. Attorney Calvin Pierre provides 24/7 emergency immigration defense. Do not open the door — call us first."
>
  <section class="section section-dark page-hero ice-hero">
    <div class="container ice-hero-grid">
      <div class="ice-hero-copy">
        <span class="hero-eyebrow">
          <Gavel size={16} stroke-width={1.8} />
          Emergency Service · 24/7 Intake
          <Gavel size={16} stroke-width={1.8} />
        </span>
        <h1>ICE Raid At Your Home Or Workplace? Know Your Rights. <span class="hero-accent">Silence Is Your Best Defense.</span></h1>
        <p>
          As a proud son of Haitian immigrants, Attorney Calvin Pierre protects the constitutional
          rights of all immigrants. We speak English, Spanish, Haitian Creole, and French.
        </p>
        <div class="ice-hero-actions">
          <a class="btn btn-whatsapp" href={brand.whatsappHref} target="_blank" rel="noopener">
            <MessageCircle size={16} stroke-width={2} />
            Emergency Help on WhatsApp
          </a>
          <a class="btn btn-primary" href={brand.phoneHref}>
            <Phone size={16} stroke-width={2} />
            Call Now: Emergency Line
          </a>
        </div>
        <p class="ice-hero-trust">
          <ShieldCheck size={15} stroke-width={2} />
          We've protected hundreds of families during ICE home, workplace, and community enforcement actions.
        </p>
      </div>
    </div>
  </section>

  <section class="support-band section-soft watermark-section">
    <div class="container support-grid">
      {trustBand.map(({ title, text, Icon }) => (
        <article class="support-item">
          <div class="support-icon"><Icon size={32} stroke-width={1.55} /></div>
          <div>
            <h2>{title}</h2>
            <p>{text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section ice-steps-section watermark-section">
    <div class="container ice-steps-grid">
      <div class="ice-steps-intro">
        <span class="hero-eyebrow">
          <AlertTriangle size={16} stroke-width={1.8} />
          What To Do Right Now
          <AlertTriangle size={16} stroke-width={1.8} />
        </span>
        <h2>What To Do Right Now During An ICE Raid</h2>
        <p>
          If ICE is at your door or workplace, follow these steps immediately to protect your rights
          and your family. Every second counts.
        </p>
        <a class="btn btn-outline" href={brand.phoneHref}>
          Call Our Emergency Line
          <ArrowRight size={16} stroke-width={1.8} />
        </a>
      </div>
      <ol class="ice-step-list">
        {steps.map((step, index) => (
          <li class="ice-step">
            <span class="ice-step-num">{String(index + 1).padStart(2, '0')}</span>
            <div class="ice-step-body">
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section ice-strategies-section">
    <div class="container">
      <div class="ice-section-head">
        <span class="hero-eyebrow">
          <Gavel size={16} stroke-width={1.8} />
          How We Protect You
          <Gavel size={16} stroke-width={1.8} />
        </span>
        <h2>How We Protect Your Rights</h2>
        <p>
          From the moment you call, our team moves on all fronts — asserting your rights, challenging
          unlawful arrests, and building your defense before ICE can act.
        </p>
      </div>
      <div class="ice-strategy-grid">
        {strategies.map(({ title, text, Icon }) => (
          <article class="ice-strategy-card">
            <span class="ice-strategy-icon"><Icon size={28} stroke-width={1.5} /></span>
            <h3>{title}</h3>
            <p>{text}</p>
            <ArrowRight class="ice-strategy-arrow" size={15} />
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section ice-stories-section">
    <div class="container">
      <div class="ice-section-head">
        <span class="hero-eyebrow">
          <Gavel size={16} stroke-width={1.8} />
          Real Results
          <Gavel size={16} stroke-width={1.8} />
        </span>
        <h2>Real Results From Families We've Helped</h2>
      </div>
      <div class="ice-stories-grid">
        {stories.map((story) => (
          <article class="ice-story-card">
            <Quote class="ice-story-quote" size={36} stroke-width={1.4} />
            <div class="ice-story-stars" aria-label={`${story.stars} out of 5 stars`}>
              {Array.from({ length: 5 }, (_, i) =>
                i < story.stars ? (
                  <Star size={16} fill="currentColor" stroke-width={0} />
                ) : (
                  <Star size={16} stroke-width={1.6} />
                )
              )}
            </div>
            <h3 class="ice-story-title">"{story.title}"</h3>
            <p>{story.text}</p>
            <footer>
              <strong>{story.name}</strong>
              <span>{story.city}</span>
            </footer>
          </article>
        ))}
      </div>
      <p class="ice-disclaimer">
        Past results do not guarantee a future outcome. Every case is different.
      </p>
    </div>
  </section>

  <section class="section ice-faq-section">
    <div class="container ice-faq-grid">
      <div class="ice-faq-copy">
        <span class="hero-eyebrow">
          <Gavel size={16} stroke-width={1.8} />
          FAQ
          <Gavel size={16} stroke-width={1.8} />
        </span>
        <h2>Your Questions Answered</h2>
        <p>
          Honest answers about your rights, what ICE can and cannot do, and what to do if you or a
          family member is arrested during a raid.
        </p>
      </div>
      <div class="ice-faq-list">
        {iceFaqs.map((faq, index) => (
          <details class="faq-item" name="ice-raid-faq" open={index === 0}>
            <summary>
              <span class="faq-q-num">{String(index + 1).padStart(2, '0')}</span>
              <span class="faq-q-text">{faq.question}</span>
              <span class="faq-q-icon" aria-hidden="true">
                <Plus size={20} stroke-width={1.75} />
              </span>
            </summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section rights-card-section watermark-section">
    <div class="container">
      <div class="rights-card-inner">
        <span class="rights-card-icon-wrap" aria-hidden="true">
          <FileDown size={32} stroke-width={1.5} />
        </span>
        <h2>Download Your Free "Know Your Rights" Card</h2>
        <p class="rights-card-lead">
          Print this card and keep it in your home, car, and workplace. It explains your rights in plain
          language — so you know exactly what to say and do if ICE arrives, even under pressure.
        </p>
        <div class="rights-card-buttons">
          {rightsCards.map(({ label }) => (
            <a
              class="btn rights-card-btn"
              href={brand.whatsappHref}
              target="_blank"
              rel="noopener"
              aria-label={`Request Know Your Rights card in ${label}`}
            >
              <FileDown size={15} stroke-width={2} />
              {label}
            </a>
          ))}
        </div>
        <p class="rights-card-note">
          Cards are sent via WhatsApp in PDF format — free of charge, no strings attached.
        </p>
      </div>
    </div>
  </section>

  <section class="section ice-final-cta watermark-section">
    <div class="container">
      <div class="ice-final-inner">
        <h2>Don't Wait &mdash; Protect Your Family Now</h2>
        <p class="ice-final-lead">
          Do not speak to ICE until you have a lawyer on the line. What people do in the first 24 hours determines everything.
        </p>
        <div class="ice-hero-actions ice-final-actions">
          <a class="btn btn-whatsapp" href={brand.whatsappHref} target="_blank" rel="noopener">
            <MessageCircle size={16} stroke-width={2} />
            Emergency Help on WhatsApp
          </a>
          <a class="btn btn-primary" href={brand.phoneHref}>
            <Phone size={16} stroke-width={2} />
            Call Now: Emergency Line
          </a>
        </div>
        <p class="ice-final-languages">
          Hablamos Español &nbsp;|&nbsp; Falamos Português &nbsp;|&nbsp; Nou pale Kreyòl &nbsp;|&nbsp; Nous parlons Français
        </p>
        <div class="ice-final-divider" aria-hidden="true"></div>
        <p class="ice-final-locations">
          <MapPin size={16} stroke-width={2} />
          Headquartered in Newark &nbsp;|&nbsp; Serving All NJ, PA &amp; NY Communities
        </p>
        <p class="ice-final-note">
          Attorney Calvin Pierre is licensed to practice immigration law throughout the United States.
          Constitutional rights apply to all people on U.S. soil, regardless of immigration status.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-eyebrow {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    padding: 8px 16px;
    color: var(--color-gold);
    background: rgba(201, 171, 105, 0.1);
    border: 1px solid rgba(201, 171, 105, 0.4);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.4px;
  }

  .hero-eyebrow svg {
    flex: 0 0 auto;
  }

  .hero-accent {
    color: var(--color-gold);
  }

  /* ── Trust band ── */
  .support-band {
    position: relative;
    z-index: 2;
    color: #ffffff;
    overflow: hidden;
    background: linear-gradient(180deg, #04102a 0%, #061227 100%);
  }

  .support-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(18px, 2vw, 28px);
    padding: 40px 0 38px;
  }

  .support-item {
    position: relative;
    display: grid;
    grid-template-columns: 50px minmax(0, 1fr);
    gap: 18px;
    align-content: start;
    min-height: 188px;
    padding: 28px 26px 24px;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.02)),
      rgba(8, 24, 56, 0.55);
    border: 1px solid rgba(201, 171, 105, 0.2);
    transition: transform 180ms ease, border-color 180ms ease;
  }

  .support-item::before {
    position: absolute;
    inset: 0 0 auto;
    height: 4px;
    content: "";
    background: linear-gradient(90deg, var(--color-gold), rgba(8, 38, 88, 0.34));
  }

  .support-item::after {
    position: absolute;
    right: -42px;
    bottom: -52px;
    width: 150px;
    height: 150px;
    content: "";
    border-radius: 999px;
    background: rgba(201, 171, 105, 0.08);
  }

  .support-item:hover {
    transform: translateY(-4px);
    border-color: rgba(201, 171, 105, 0.34);
  }

  .support-icon {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    aspect-ratio: 1;
    color: var(--color-gold);
    background: rgba(201, 171, 105, 0.14);
    border: 1px solid rgba(201, 171, 105, 0.36);
    border-radius: 50%;
  }

  .support-item h2 {
    position: relative;
    z-index: 1;
    margin: 0 0 12px;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(1.22rem, 1.45vw, 1.52rem);
    font-weight: 700;
    line-height: 1.08;
  }

  .support-item p {
    position: relative;
    z-index: 1;
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.58;
  }

  @media (max-width: 900px) {
    .support-grid {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 42px 0;
    }
  }

  /* ── Hero ── */
  .ice-hero {
    color: #ffffff;
  }

  .ice-hero-grid {
    display: grid;
    gap: 28px;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .ice-hero-copy .hero-eyebrow {
    align-self: center;
    margin: 0 auto 22px;
  }

  .ice-hero-copy h1 {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(2.05rem, 3.8vw, 3.4rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: 0.4px;
    text-transform: uppercase;
  }

  .ice-hero-copy > p {
    max-width: 720px;
    margin: 22px auto 32px;
    color: rgba(255, 255, 255, 0.78);
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.2vw, 1.12rem);
    line-height: 1.6;
  }

  .ice-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
  }

  .ice-hero-actions .btn {
    gap: 10px;
    min-width: 220px;
    min-height: 56px;
    justify-content: center;
    font-size: 0.88rem;
  }

  .btn-whatsapp {
    background: #1faa5a;
    color: #ffffff;
    border: 0;
  }

  .btn-whatsapp:hover {
    background: #178d4a;
    color: #ffffff;
  }

  .ice-hero-trust {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    justify-content: center;
    max-width: 680px;
    margin: 30px auto 0;
    padding: 12px 22px;
    background: rgba(201, 171, 105, 0.1);
    border: 1px solid rgba(201, 171, 105, 0.34);
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.86);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-style: italic;
  }

  .ice-hero-trust svg {
    flex: 0 0 auto;
    color: var(--color-gold);
  }

  /* ── Steps section ── */
  .ice-steps-section {
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 18%, rgba(201, 171, 105, 0.1), transparent 32%),
      linear-gradient(180deg, #061227 0%, #04102a 100%);
  }

  .ice-steps-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(48px, 6vw, 100px);
    align-items: start;
  }

  .ice-steps-intro {
    position: sticky;
    top: 130px;
    display: grid;
    gap: 22px;
    align-content: start;
  }

  .ice-steps-intro .hero-eyebrow {
    align-self: start;
    margin: 0;
  }

  .ice-steps-intro h2 {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(1.85rem, 3vw, 2.85rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: 0.4px;
    text-transform: uppercase;
  }

  .ice-steps-intro p {
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.98rem;
    line-height: 1.7;
  }

  .ice-steps-intro .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    align-self: start;
    margin-top: 8px;
    padding: 16px 26px;
    color: #ffffff;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.32);
    border-radius: 4px;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    transition: background 200ms ease, border-color 200ms ease, color 200ms ease;
  }

  .ice-steps-intro .btn-outline:hover {
    color: #0a1f44;
    background: var(--color-gold);
    border-color: var(--color-gold);
  }

  .ice-step-list {
    position: relative;
    margin: 0;
    padding: 4px 0 0;
    list-style: none;
  }

  .ice-step-list::before {
    position: absolute;
    top: 44px;
    bottom: 44px;
    left: 21px;
    width: 0;
    content: "";
    border-left: 2px dotted rgba(255, 255, 255, 0.22);
  }

  .ice-step {
    position: relative;
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr);
    gap: 28px;
    padding: 0 0 36px;
  }

  .ice-step:last-child {
    padding-bottom: 0;
  }

  .ice-step-num {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    background: var(--color-gold);
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: 0.86rem;
    font-weight: 700;
    box-shadow: 0 14px 28px rgba(201, 171, 105, 0.32);
  }

  .ice-step-body h3 {
    margin: 0 0 12px;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 1.6vw, 1.5rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .ice-step-body p {
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    line-height: 1.72;
  }

  /* ── Strategy cards ── */
