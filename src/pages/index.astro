---
import {
  ArrowRight,
  BriefcaseBusiness,
  Gavel,
  Handshake,
  Headphones,
  Landmark,
  Languages,
  Lightbulb,
  Plus,
  Scale,
  ShieldCheck,
} from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { assets, brand, faqs, processSteps, services } from '../data/site';

const serviceIcons = [ShieldCheck, Gavel, Handshake, Languages, Landmark, BriefcaseBusiness];
const homeServiceSlugs = [
  'deportation-defense-removal-proceedings',
  'habeas-corpus',
  'asylum',
  'appeals',
  'bond-hearings',
  'citizenship',
];
const homeServices = homeServiceSlugs
  .map((slug) => services.find((service) => service.slug === slug))
  .filter((service): service is (typeof services)[number] => Boolean(service));
const supportItems = [
  {
    title: 'Dedicated Client Support',
    text: 'Our team is always available to answer your questions, guide you through the process, and ensure you feel supported at every step.',
    Icon: Headphones,
  },
  {
    title: 'Trusted Legal Expertise',
    text: 'With years of experience in immigration, civil litigation, and business law we provide strong representation and practical solutions tailored to your needs.',
    Icon: Scale,
  },
  {
    title: 'All-In-One Legal Help',
    text: 'From consultations to court representation, we handle every detail with care, delivering the best outcome for you and your family.',
    Icon: Lightbulb,
  },
];
const heroSlides = [
  {
    title: 'Legal Support For Families Facing ICE Detention & Removal',
    text: 'Guiding families through immigration challenges with clarity and care',
    image: assets.hero,
    href: '/book-now/',
    cta: 'Book An Appointment',
    CtaIcon: Scale,
  },
  {
    title: 'Support For Asylum, Family Petitions & Relief Options',
    text: 'Personalized legal solutions focused on keeping families together and securing your future',
    image: assets.slide2,
    href: '#consultation',
    cta: 'Free Consultation',
    CtaIcon: ArrowRight,
  },
  {
    title: 'Protecting Your Rights During Immigration Proceedings',
    text: 'Strategic, informed advocacy to help you navigate complex legal systems with confidence',
    image: assets.slide3,
    href: '#consultation',
    cta: 'Free Consultation',
    CtaIcon: ArrowRight,
  },
];
---

<BaseLayout
  title={`${brand.attorneyName} | Immigration Lawyer in Newark, NJ`}
  description="Professional immigration law representation for asylum, deportation defense, bond hearings, citizenship, appeals, visas, and urgent detention matters."
>
  <section class="hero" data-hero-slider>
    {heroSlides.map((slide, index) => {
      const CtaIcon = slide.CtaIcon;
      return (
        <article class={`hero-slide ${index === 0 ? 'is-active' : ''}`} data-slide-index={index}>
          <div class="hero-bg" aria-hidden="true">
            <img src={slide.image} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
          </div>
          <div class="container hero-grid">
            <div class="hero-copy">
              <span class="hero-eyebrow">
                <Gavel size={16} stroke-width={1.8} />
                {brand.bar}
                <Gavel size={16} stroke-width={1.8} />
              </span>
              <h1>{slide.title}</h1>
              <p>{slide.text}</p>
              <div class="hero-actions">
                <a class="btn btn-primary" href={slide.href}>
                  {slide.cta}
                  <CtaIcon size={16} stroke-width={1.8} />
                </a>
                <a class="btn btn-secondary" href={brand.phoneHref}>Call {brand.phone}</a>
              </div>
            </div>
            <div class="hero-figure" aria-hidden="true">
              <img src={slide.image} alt="" width="2048" height="1365" loading={index === 0 ? 'eager' : 'lazy'} />
            </div>
          </div>
        </article>
      );
    })}
    <div class="hero-dots" role="tablist" aria-label="Hero slides">
      {heroSlides.map((_, index) => (
        <button
          type="button"
          class={`hero-dot ${index === 0 ? 'is-active' : ''}`}
          data-slide-target={index}
          aria-label={`Slide ${index + 1}`}
        ></button>
      ))}
    </div>
  </section>

  <script>
    const slider = document.querySelector('[data-hero-slider]');
    if (slider) {
      const slides = Array.from(slider.querySelectorAll<HTMLElement>('.hero-slide'));
      const dots = Array.from(slider.querySelectorAll<HTMLButtonElement>('.hero-dot'));
      let current = 0;
      let timer: ReturnType<typeof setInterval> | null = null;

      const show = (next: number) => {
        slides[current]?.classList.remove('is-active');
        dots[current]?.classList.remove('is-active');
        current = (next + slides.length) % slides.length;
        slides[current]?.classList.add('is-active');
        dots[current]?.classList.add('is-active');
      };

      const start = () => {
        stop();
        timer = setInterval(() => show(current + 1), 6000);
      };
      const stop = () => {
        if (timer) {
          clearInterval(timer);
          timer = null;
        }
      };

      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          show(index);
          start();
        });
      });

      slider.addEventListener('mouseenter', stop);
      slider.addEventListener('mouseleave', start);
      start();
    }
  </script>

  <section class="support-band section-soft watermark-section">
    <div class="container support-grid">
      {supportItems.map(({ title, text, Icon }) => (
        <article class="support-item">
          <div class="support-icon"><Icon size={58} stroke-width={1.55} /></div>
          <div>
            <h2>{title}</h2>
            <p>{text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-soft watermark-section about-section">
    <div class="container about-grid">
      <div class="portrait-frame">
        <img src={assets.portrait} alt={brand.attorneyName} loading="lazy" />
      </div>
      <div class="about-copy">
        <p class="eyebrow">What About Us</p>
        <h2>Experienced & Ready To Help.</h2>
        <p>
          I am a proud son of Haitian immigrants and a first-generation American who
          understands firsthand the challenges and hopes that come with building a
          new life in this country. From an early age, I was taught the value of hard
          work, perseverance, and integrity-principles that continue to guide my
          practice today.
        </p>
        <p>
          My passion for immigration law is deeply personal, and I have dedicated my
          career to helping individuals and families navigate the complexities of the
          U.S. immigration system.
        </p>
        <div class="signature-row">
          <span>Calvin Pierre</span>
          <a href="/about/">Read more <ArrowRight size={14} /></a>
        </div>
      </div>
    </div>
  </section>

  <section class="section practice-section">
    <div class="container">
      <div class="center-title">
        <h2>Practice Areas</h2>
        <p>We provide expert legal services in a range of practice areas to serve your needs:</p>
      </div>
      <div class="practice-grid">
        {homeServices.map((service, index) => {
          const Icon = serviceIcons[index] ?? Scale;
          return (
            <a class="practice-item" href={`/practice-areas/${service.slug}/`}>
              <Icon size={34} stroke-width={1.35} />
              <h3>{service.title}</h3>
              <p>{service.summary}</p>
              <ArrowRight class="item-arrow" size={15} />
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section section-soft watermark-section process-section">
    <div class="container process-grid">
      <div class="process-intro">
        <span class="process-eyebrow">Our Work Process</span>
        <h2>Understanding Our Work Process</h2>
        <div class="process-image">
          <img src={assets.team} alt="Pierre Vanguard Law team in a client meeting" loading="lazy" />
        </div>
      </div>
      <ol class="process-steps">
        {processSteps.map((step) => (
          <li class="process-step">
            <span class="process-number">{step.number}</span>
            <div class="process-body">
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container faq-grid">
      <div class="faq-copy">
        <span class="faq-eyebrow">Question</span>
        <h2>Frequently Asked Questions For Clients?</h2>
        <div class="faq-list">
          {faqs.map((faq, index) => (
            <details class="faq-item" name="home-faqs" open={index === 1}>
              <summary>
                <span class="faq-q-num">{String(index + 1).padStart(2, '0')}</span>
                <span class="faq-q-text">{faq.question}</span>
                <span class="faq-q-icon" aria-hidden="true">
                  <Plus size={20} stroke-width={1.75} />
                </span>
              </summary>
              <div class="faq-answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
      <div class="faq-figure">
        <div class="faq-frame" aria-hidden="true"></div>
        <img src={assets.portrait} alt={`${brand.attorneyName} on a client call`} loading="lazy" />
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: clamp(690px, calc(100svh - 129px), 900px);
    overflow: hidden;
    color: #ffffff;
    background: var(--color-night);
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 700ms ease;
  }

  .hero-slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(3, 12, 28, 1) 0%, rgba(5, 18, 39, 0.98) 34%, rgba(5, 18, 39, 0.62) 66%, rgba(5, 18, 39, 0.98) 100%),
      radial-gradient(circle at 62% 32%, rgba(67, 133, 255, 0.28), transparent 31%),
      linear-gradient(135deg, var(--color-navy) 0%, var(--color-navy-2) 58%, #020814 100%);
  }

  .hero-bg::before {
    position: absolute;
    inset: 0;
    content: "";
    opacity: 0.32;
    background:
      linear-gradient(90deg, transparent 0, rgba(255, 255, 255, 0.05) 50%, transparent 100%),
      repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.018) 0 1px, transparent 1px 92px);
  }

  .hero-bg::after {
    position: absolute;
    inset: 0;
    content: "";
    background:
      linear-gradient(90deg, rgba(3, 12, 28, 0.98) 0%, rgba(5, 18, 39, 0.9) 38%, rgba(5, 18, 39, 0.55) 72%, rgba(5, 18, 39, 0.92) 100%),
      radial-gradient(circle at 70% 38%, rgba(201, 171, 105, 0.18), transparent 34%);
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.32;
    filter: saturate(0.88) contrast(1.05);
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(0, 1fr);
    align-items: end;
    min-height: clamp(620px, calc(100svh - 129px), 900px);
    padding: 90px 0 98px;
  }

  .hero-copy {
    align-self: center;
    z-index: 4;
    max-width: 980px;
    padding: 8px 0 0 62px;
    transform: translateY(16px);
    opacity: 0;
    transition:
      opacity 620ms ease 160ms,
      transform 620ms ease 160ms;
  }

  .hero-slide.is-active .hero-copy {
    transform: translateY(0);
    opacity: 1;
  }

  .hero-eyebrow {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 28px;
    padding: 9px 18px;
    color: var(--color-gold);
    background: rgba(201, 171, 105, 0.1);
    border: 1px solid rgba(201, 171, 105, 0.4);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.4px;
  }

  .hero-eyebrow svg {
    flex: 0 0 auto;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
  }

  .hero-copy h1 {
    max-width: 780px;
    margin: 0;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 4vw, 4rem);
    font-weight: 700;
    line-height: 1.06;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .hero-copy p {
    margin: 30px 0 72px;
    color: rgba(255, 255, 255, 0.84);
    font-size: 1.5rem;
    line-height: 1.35;
    font-weight: 400;
  }

  .hero-copy .btn {
    gap: 10px;
  }

  .hero-copy .btn {
    min-width: 365px;
    min-height: 72px;
    justify-content: center;
    font-size: 1rem;
  }

  .hero-figure {
    position: absolute;
    z-index: 2;
    right: -80px;
    bottom: 0;
    width: min(54vw, 880px);
    height: 100%;
    min-height: 0;
    overflow: visible;
    pointer-events: none;
    transform: translateX(34px);
    opacity: 0;
    transition:
      opacity 700ms ease 220ms,
      transform 700ms ease 220ms;
  }

  .hero-slide.is-active .hero-figure {
    transform: translateX(0);
    opacity: 1;
  }

  .hero-figure img {
    position: absolute;
    right: -90px;
    bottom: 0;
    width: min(1040px, 64vw);
    max-height: min(760px, calc(100% - 18px));
    max-width: none;
    height: auto;
    object-fit: contain;
    filter:
      saturate(0.95)
      contrast(1.05)
      drop-shadow(0 54px 100px rgba(0, 0, 0, 0.56));
  }

  .hero-dots {
    position: absolute;
    top: 50%;
    right: clamp(20px, 2.4vw, 44px);
    z-index: 6;
    display: inline-flex;
    flex-direction: column;
    gap: 22px;
    align-items: center;
    transform: translateY(-50%);
  }

  .hero-dot {
    position: relative;
    width: 10px;
    height: 10px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.55);
    cursor: pointer;
    transition: background 220ms ease, transform 220ms ease;
  }

  .hero-dot::before {
    position: absolute;
    inset: -10px;
    content: "";
    border: 1.5px solid transparent;
    border-radius: 999px;
    transition: border-color 220ms ease, inset 220ms ease;
  }

  .hero-dot.is-active {
    background: #ffffff;
  }

  .hero-dot.is-active::before {
    inset: -8px;
    border-color: #ffffff;
  }

  .hero-dot:hover {
    background: #ffffff;
  }

  .hero-dot:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 6px;
  }

  @media (max-width: 640px) {
    .hero-dots {
      right: 14px;
      gap: 18px;
    }
  }

  .support-band {
    position: relative;
    z-index: 2;
    color: #ffffff;
    overflow: hidden;
    background:
      linear-gradient(180deg, #04102a 0%, #061227 100%);
  }

  .support-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(18px, 2vw, 28px);
    padding: 40px 0 38px;
  }

  .support-item {
    position: relative;
    display: grid;
    grid-template-columns: 50px minmax(0, 1fr);
    gap: 18px;
    align-content: start;
    min-height: 188px;
    padding: 28px 26px 24px;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.02)),
      rgba(8, 24, 56, 0.55);
    border: 1px solid rgba(201, 171, 105, 0.2);
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .support-item::before {
    position: absolute;
    inset: 0 0 auto;
    height: 4px;
    content: "";
    background: linear-gradient(90deg, var(--color-gold), rgba(8, 38, 88, 0.34));
  }

  .support-item::after {
    position: absolute;
    right: -42px;
    bottom: -52px;
    width: 150px;
    height: 150px;
    content: "";
    border-radius: 999px;
    background: rgba(201, 171, 105, 0.08);
  }

  .support-item:hover {
    transform: translateY(-4px);
    border-color: rgba(201, 171, 105, 0.34);
  }

  .support-icon {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    aspect-ratio: 1;
    color: var(--color-gold);
    background: rgba(201, 171, 105, 0.14);
    border: 1px solid rgba(201, 171, 105, 0.36);
    border-radius: 50%;
  }

  .support-item h2 {
    position: relative;
    z-index: 1;
    margin: 0 0 12px;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(1.22rem, 1.45vw, 1.52rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .support-item p {
    position: relative;
    z-index: 1;
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.58;
  }

  @media (max-width: 1500px), (max-height: 880px) {
    .hero,
    .hero-grid {
      min-height: 700px;
    }

    .hero-grid {
      grid-template-columns: minmax(0, 0.9fr) minmax(460px, 1fr);
      padding: 56px 0 72px;
    }

    .hero-copy {
      max-width: 780px;
      padding-left: 36px;
    }

    .hero-copy h1 {
      font-size: clamp(2.18rem, 3vw, 2.9rem);
      line-height: 1.08;
    }

    .hero-copy p {
      margin: 24px 0 46px;
      font-size: 1.1rem;
    }

    .hero-copy .btn {
      min-width: 320px;
      min-height: 62px;
      font-size: 0.9rem;
    }

    .hero-figure {
      right: -74px;
      width: min(53vw, 720px);
    }

    .hero-figure img {
      right: -16px;
      width: min(820px, 56vw);
      max-height: 620px;
    }

  }

  .about-section {
    position: relative;
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(320px, 470px) minmax(0, 1fr);
    gap: clamp(64px, 8vw, 118px);
    align-items: center;
  }

  .portrait-frame {
    width: min(100%, 430px);
    margin-left: clamp(0px, 5vw, 42px);
    background: rgba(255, 255, 255, 0.04);
  }

  .portrait-frame img {
    width: 100%;
    aspect-ratio: 0.78;
    object-fit: cover;
  }

  .about-copy {
    max-width: 650px;
  }

  .about-copy .eyebrow {
    margin-bottom: 14px;
    color: var(--color-blue);
    font-family: var(--font-serif);
    font-size: clamp(1.65rem, 2.4vw, 2.5rem);
    font-weight: 700;
    line-height: 1;
    text-transform: none;
    letter-spacing: 0;
  }

  .about-copy h2,
  .center-title h2 {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(2.05rem, 3.9vw, 3.75rem);
    line-height: 1.08;
    letter-spacing: 0;
  }

  .about-copy p {
    max-width: 570px;
    margin: 14px 0 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.74;
  }

  .about-copy h2 + p {
    margin-top: 22px;
  }

  .signature-row {
    display: flex;
    gap: clamp(28px, 7vw, 120px);
    align-items: end;
    margin-top: 34px;
  }

  .signature-row span {
    color: var(--color-gold);
    font-family: "Brush Script MT", "Segoe Script", cursive;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1;
  }

  .signature-row a {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    color: #ffffff;
    padding-bottom: 10px;
    font-size: 0.82rem;
    font-weight: 800;
  }

  .practice-section {
    color: #ffffff;
    background:
      radial-gradient(circle at 80% 20%, rgba(201, 171, 105, 0.1), transparent 32%),
      linear-gradient(180deg, #04102a 0%, #061227 100%);
  }

  .center-title {
    max-width: 760px;
    margin: 0 auto 58px;
    text-align: center;
  }

  .center-title p {
    margin: 22px 0 0;
    color: rgba(255, 255, 255, 0.68);
    font-weight: 500;
  }

  .practice-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 64px 84px;
  }

  .practice-item {
    display: block;
  }

  .practice-item svg {
    color: var(--color-gold);
  }

  .practice-item h3 {
    margin: 22px 0 12px;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: 1.28rem;
    line-height: 1.2;
  }

  .practice-item p {
    max-width: 305px;
    margin: 0;
    color: rgba(255, 255, 255, 0.66);
    font-size: 0.92rem;
  }

  .practice-item .item-arrow {
    margin-top: 14px;
    color: var(--color-gold);
  }

  .process-section {
    position: relative;
  }

  .process-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: clamp(56px, 7vw, 110px);
    align-items: start;
  }

  .process-eyebrow {
    display: inline-block;
    padding: 9px 18px;
    background: rgba(201, 171, 105, 0.14);
    color: var(--color-gold);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
  }

  .process-intro h2 {
    margin: 28px 0 44px;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(2.05rem, 3.9vw, 3.75rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .process-image {
    position: relative;
    max-width: 540px;
  }

  .process-image img {
    width: 100%;
    aspect-ratio: 1.35;
    object-fit: cover;
    box-shadow: 0 38px 90px rgba(15, 26, 56, 0.18);
  }

  .process-steps {
    position: relative;
    padding: 4px 0 0;
    margin: 0;
    list-style: none;
  }

  .process-steps::before {
    position: absolute;
    top: 44px;
    bottom: 44px;
    left: 21px;
    width: 0;
    content: "";
    border-left: 2px dotted rgba(255, 255, 255, 0.22);
  }

  .process-step {
