---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { brand, emergencyServices, services } from '../../data/site';

export function getStaticPaths() {
  return services
    .filter((service) => service.slug !== 'work-visas-employment-authorization')
    .map((service) => ({
      params: { slug: service.slug },
      props: { service },
    }));
}

const { service } = Astro.props;
const detail = (service as typeof service & { detail?: {
  headline: string;
  intro: string;
  subhead: string;
  points: { lead: string; body: string }[];
  closing: string;
} }).detail;
---

<BaseLayout
  title={`${service.title} | ${brand.firmName}`}
  description={`${service.summary} Schedule a confidential immigration consultation with ${brand.attorneyName}.`}
>
  <section class="service-hero section-dark page-hero">
    <div class="container service-grid">
      <div class="section-title">
        <p class="eyebrow">Practice Area</p>
        <h1>{detail ? detail.headline : service.title}</h1>
        <p>{service.summary}</p>
        <div class="actions">
          <a class="btn btn-primary" href="/book-now/">Book Consultation</a>
          <a class="btn btn-secondary" href={brand.phoneHref}>Call {brand.phone}</a>
        </div>
      </div>
      <img src={service.image} alt="" loading="eager" />
    </div>
  </section>

  <section class="prose-page watermark-section">
    <div class="container content-grid">
      <article class="prose-article">
        {detail ? (
          <>
            <p class="lead">{detail.intro}</p>
            <h2>{detail.subhead}</h2>
            <ul class="points">
              {detail.points.map((point) => (
                <li>
                  <strong>{point.lead}</strong>
                  <span>{point.body}</span>
                </li>
              ))}
            </ul>
            <p>{detail.closing}</p>
          </>
        ) : (
          <>
            <h2>Strategic immigration representation</h2>
            <p>
              Every immigration case turns on facts, timing, evidence, and the legal
              options available to the client. This page is structured for a deeper
              final writeup covering eligibility, filing strategy, deadlines,
              documents, interviews, hearings, and next steps.
            </p>
            <h2>Built for search and campaigns</h2>
            <p>
              The layout supports service-specific FAQs, local Newark language,
              national representation notes, related service links, consultation
              calls to action, and campaign tracking.
            </p>
          </>
        )}
      </article>
      <aside class="side-panel">
        <h2>Urgent Help</h2>
        {emergencyServices.map((item) => (
          <a href={`/emergency-services/${item.slug}/`}>
            <strong>{item.title}</strong>
            <span>{item.summary}</span>
          </a>
        ))}
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .service-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(380px, 0.75fr);
    gap: 44px;
    align-items: center;
  }

  .service-grid img {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 0;
    object-fit: cover;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 52px;
    align-items: start;
  }

  .prose-article {
    display: grid;
    gap: 14px;
  }

  .prose-article h2 {
    position: relative;
    margin: 30px 0 22px;
    padding-bottom: 16px;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(1.55rem, 2.4vw, 2.15rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: 0;
  }

  .prose-article h2::after {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 48px;
    height: 3px;
    content: "";
    background: var(--color-gold);
  }

  .prose-article .lead {
    max-width: 720px;
    margin: 0;
    color: rgba(255, 255, 255, 0.82);
    font-family: var(--font-sans);
    font-size: 1.06rem;
    font-weight: 500;
    line-height: 1.78;
  }

  .prose-article p {
    max-width: 720px;
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
    font-family: var(--font-sans);
    font-size: 0.98rem;
    font-weight: 500;
    line-height: 1.75;
  }

  .points {
    display: grid;
    gap: 14px;
    padding: 0;
    margin: 4px 0 24px;
    list-style: none;
  }

  .points li {
    display: grid;
    gap: 8px;
    padding: 20px 24px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-left: 3px solid var(--color-gold);
    transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
  }

  .points li:hover {
    transform: translateX(3px);
    box-shadow: 0 18px 38px rgba(0, 0, 0, 0.34);
    border-color: rgba(201, 171, 105, 0.55);
  }

  .points strong {
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: 1.02rem;
    font-weight: 800;
    letter-spacing: 0.2px;
  }

  .points span {
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-sans);
    font-size: 0.94rem;
    font-weight: 500;
    line-height: 1.72;
  }

  .side-panel {
    display: grid;
    gap: 12px;
    padding: 22px;
    border-radius: 0;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .side-panel h2 {
    margin: 0 0 8px;
    color: #ffffff;
  }

  .side-panel a {
    display: grid;
    gap: 5px;
    padding: 14px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0;
    background: rgba(255, 255, 255, 0.04);
  }

  .side-panel strong {
    color: #ffffff;
  }

  .side-panel span {
    color: rgba(255, 255, 255, 0.66);
    font-size: 0.92rem;
  }

  @media (max-width: 900px) {
    .service-grid,
    .content-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
