---
import {
  ArrowRight,
  Award,
  BadgeCheck,
  BookOpen,
  Briefcase,
  CheckCircle2,
  Clock,
  CreditCard,
  Download,
  FileText,
  Globe,
  Handshake,
  Heart,
  Lightbulb,
  Mail,
  MapPin,
  MessageCircle,
  Phone,
  Plus,
  Quote,
  Scale,
  ShieldCheck,
  Sparkles,
  Star,
  Users,
  Wallet,
} from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { brand } from '../../data/site';

const keyPoints = [
  { text: 'Multiple pathways — Family, employment, humanitarian, and special programs' },
  { text: 'Comprehensive strategy — we identify every option you qualify for' },
  { text: 'All complexity handled — from straightforward to the most complex cases' },
  { text: 'Massive expertise — experienced across all green card processes and categories' },
  { text: 'Multiple languages — thorough coaching for USCIS interviews in your language' },
  { text: 'Long-term planning — green card strategy with a path to citizenship readiness' },
];

const steps = [
  {
    number: '01',
    title: 'Comprehensive Eligibility Analysis & Pathway Selection',
    body: "Every person's journey is unique because every person's immigration history and circumstances are different. We start with a full analysis of all pathways you qualify for — family-based, employment-based, humanitarian, and special categories — then rank them by speed, cost, and likelihood of success.",
  },
  {
    number: '02',
    title: 'Document Collection & Evidence Building',
    body: 'We provide a tailored document checklist based on your specific pathway. We help you gather relationship evidence, financial documents, identity records, and supporting affidavits. When traditional documents are missing, we build your case using alternative evidence accepted by USCIS.',
  },
  {
    number: '03',
    title: 'Petition Filing (I-130, I-140, I-485, or Category-Specific Forms)',
    body: 'We prepare and file the correct petition for your pathway — I-130 for family, I-140 for employment, I-360 for special categories. For eligible applicants in the US, we concurrently file I-485 Adjustment of Status with I-765 (work permit) and I-131 (travel document) to maximize efficiency.',
  },
  {
    number: '04',
    title: 'Research & Background Checks',
    body: 'USCIS conducts extensive background checks on all green card applicants. We prepare you for this stage by reviewing your full history — prior immigration violations, criminal records, travel history, and any potential bars — and addressing each issue strategically before it becomes a problem.',
  },
  {
    number: '05',
    title: 'Request for Evidence (RFE) Response (if needed)',
    body: 'RFEs are common in green card cases and require comprehensive, persuasive responses filed within strict deadlines. We draft thorough RFE responses supported by additional evidence and legal argument. Our RFE approval rate is 94% — we know what USCIS wants to see.',
  },
  {
    number: '06',
    title: 'Interview Preparation & USCIS Interview',
    body: 'Most green card applicants must attend an interview at a USCIS field office or U.S. consulate. We conduct mock interviews tailored to your specific case, prepare you for the most common questions, review all your documents for consistency, and brief you on what to expect the day of your interview.',
  },
  {
    number: '07',
    title: 'Approval & Green Card Issuance',
    body: 'Upon approval, USCIS mails your green card. For conditional residents (married less than 2 years or EB-5 investors), this is a 2-year conditional card. We track every case through final approval and notify you immediately when your card ships.',
  },
  {
    number: '08',
    title: 'Conditional Green Card Removal (if applicable) & Citizenship Planning',
    body: 'If you received a conditional green card, we file the I-751 petition to remove conditions 90 days before it expires. We also begin planning your naturalization timeline — ensuring you know exactly when you become eligible and what steps to take toward U.S. citizenship.',
  },
];

const stories = [
  {
    name: 'The Jean-Baptiste Family',
    category: 'Haiti — Family-Based I-130',
    stars: 5,
    text: 'Attorney Pierre made it happen in 14 months. Our vet returned to full employment and our family is finally together in the US. We had been separated for 7 years waiting for the right attorney. We would never forget what his team did for us.',
  },
  {
    name: 'Dr. Paul Thomas',
    category: 'Employment-Based NIW I-140',
    stars: 5,
    text: "They showed me I didn't need my employer to sponsor me. The NIW path changed everything. I filed my own I-140, it was approved in 4 months, and I am now a permanent resident working at a hospital I chose. Attorney Pierre believed in my case when others didn't.",
  },
  {
    name: 'María & Carlos O.',
    category: 'Orlando — Marriage-Based With Waiver',
    stars: 5,
    text: "I thought my prior unlawful presence meant I could never get a green card. They proved me wrong. Attorney Pierre filed the I-601A provisional waiver and it was approved. We went to the consulate and I got my immigrant visa. That was 8 months ago and I'm finally home.",
  },
  {
    name: 'Sandra L.',
    category: 'Asylum-Based Adjustment',
    stars: 5,
    text: 'I filed my asylum application by myself and it was approved. But I did not know I could adjust to a green card. Attorney Pierre explained the process, filed my I-485, and I received my green card 11 months later. I am now applying for citizenship.',
  },
  {
    name: 'The Rodriguez Family',
    category: 'Tijuana — VAWA Self-Petition',
    stars: 5,
    text: 'I completed my VAWA application without my abusive husband. This saved my children and myself. Attorney Pierre handled everything with care and confidentiality. The green card changed my life completely — I now work legally and my children are thriving.',
  },
  {
    name: 'The Chen Family',
    category: 'Orlando — EB-3 Employment-Based',
    stars: 5,
    text: "I thought my situation meant I could never get my whole family green cards together. Attorney Pierre designed a strategy that got all five of us approved within 18 months of each other. I cannot believe we are all permanent residents now.",
  },
];

const challenges = [
  {
    number: '1',
    title: 'Extremely Long Wait Times (Priority Date Backlogs)',
    problem: 'EB-2 and EB-3 green cards from India, China, the Philippines, El Salvador, and Mexico face backlogs of 5 to 25+ years due to per-country annual limits. Even family-based categories have multi-year waits. Many clients feel paralyzed, not knowing what to do while they wait.',
    solution: "We help you make the most of every year in the backlog. We identify strategic upgrades — if a petition becomes EB-1 eligible, upgrading can move your priority date years forward. We coordinate concurrent filings to capture earlier priority dates, assist with AC21 job portability after I-485 is pending 180+ days, and keep your petition alive and protected through employer or life changes.",
  },
  {
    number: '2',
    title: 'Inadmissibility Issues (Past Immigration Violations)',
    problem: 'Prior unlawful presence, misrepresentation, prior removals, prior orders of deportation, and certain criminal convictions can bar someone from receiving a green card. Many people assume they are permanently barred when waivers may be available.',
    solution: "We assess every bar and identify all available waivers. I-601 Waiver handles most grounds of inadmissibility if you can show extreme hardship to a U.S. citizen or permanent resident spouse or parent. I-601A Provisional Waivers allow qualifying applicants to obtain waiver approval before attending their consulate interview. We've successfully removed inadmissibility bars for hundreds of clients who were told by other attorneys they had no options.",
  },
  {
    number: '3',
    title: 'Financial Requirements & Affidavit Of Support',
    problem: "Immigration law requires green card sponsors to prove annual income at 125% of the federal poverty line — a level many family members can't meet alone, especially if retired, part-time, or recently unemployed.",
    solution: "We use every legal tool to meet the financial requirement. Joint sponsors — any willing U.S. citizen or permanent resident who meets income requirements can co-sponsor. Household member income can be counted when the household member is domiciled with the sponsor. Assets such as bank accounts, property, and investments can substitute for insufficient income (valued at 1/5 of the shortfall). We've successfully overcome financial requirement challenges for hundreds of cases where families initially thought they didn't qualify.",
  },
  {
    number: '4',
    title: 'Proving Bona Fide Relationships (Marriage-Based Cases)',
    problem: "USCIS is notorious for scrutinizing marriage-based green cards and accusing couples of fraud. Large age differences, short courtships, different nationalities, prior marriages, and lack of shared financial accounts are all flagged as 'red flags' — even for completely genuine couples.",
    solution: "We prepare marriage-based cases with thorough, organized evidence packages that anticipate USCIS concerns. Evidence includes joint financial accounts and leases, photos throughout the relationship, correspondence history, travel records together, affidavits from family and friends, and evidence of shared life. We conduct mock interviews that mirror the real USCIS interview environment. Our marriage-based green card approval rate is 97%.",
  },
  {
    number: '5',
    title: 'Employment-Based Complications (Labor Certification, Employer Issues)',
    problem: 'Employment green cards (EB-2, EB-3) require PERM labor certification, which takes 1-2 years and requires perfect compliance. Employers change, companies close, and sponsorship can be withdrawn — leaving applicants in limbo after years of waiting.',
    solution: "We've successfully navigated hundreds of employment-based cases. For PERM cases, we work closely with employers to ensure perfect labor certification. We prepare for job changes by filing strategically to preserve priority dates and use AC21 portability after I-485 is pending 180+ days. We analyze every employment-based client for EB-1 or NIW self-petition eligibility — which eliminates employer dependency entirely. The advantage of NIW and EB-1 is that you control your own green card case.",
  },
  {
    number: '6',
    title: 'Documentation For People Without Traditional Records',
    problem: "Immigrants commonly don't have birth certificates, marriage certificates, or verifiable records — especially those from countries with poor civil documentation, those who fled as refugees, or those whose records were destroyed by disaster or conflict.",
    solution: "We specialize in building complete cases using alternative documentation accepted by USCIS. For missing birth certificates: secondary evidence such as baptismal records, school records, affidavits from elder family members, and DNA testing. For verbal or community-based documentation: sworn affidavits from community leaders, religious leaders, and long-term neighbors. For broken document chains: consular documentation, country-condition reports, and expert declarations. We've successfully obtained green cards for hundreds of clients who thought their lack of documents made it impossible.",
  },
];

const pricingCards = [
  {
    title: 'Family-Based Green Card (Immediate Relatives — Adjustment)',
    price: '$8,500 – $10,000',
    note: 'Depending On Adjustment Vs. Consular Processing',
    included: [
      'Eligibility analysis and pathway strategy',
      'I-130 petition preparation and filing',
      'I-485 Adjustment of Status (if in US)',
      'I-765 work permit and I-131 travel document',
      'Medical exam guidance',
      'Interview preparation and mock interview',
      'Full case monitoring through approval',
    ],
    notIncluded: [
      'USCIS filing fees (~$1,440 for I-485 package)',
      'Medical examination fee (~$200–$500)',
      'Translation costs if needed',
    ],
  },
  {
    title: 'Family-Based Green Card (Complex Cases)',
    price: '$7,000 – $12,000',
    note: 'Quote After Consultation',
    included: [
      'All items in standard family package',
      'Waiver preparation (I-601 or I-601A)',
      'Consular processing if outside US',
      'Criminal record analysis and strategy',
      'RFE response included',
      'Priority handling for complex situations',
    ],
    notIncluded: [
      'USCIS/consular government fees',
      'Waiver government fee ($930)',
      'Civil surgeon medical exam',
    ],
  },
  {
    title: 'Family-Based Green Card (Between Employee And Employer)',
    price: '$10,000 – $22,000',
    note: 'Attorney Fee — Quote After Consultation',
    included: [
      'PERM labor certification preparation',
      'I-140 immigrant petition filing',
      'Priority date strategy and monitoring',
      'I-485 filing when priority date current',
      'AC21 portability analysis',
      'Employer coordination and compliance',
      'RFE response included',
    ],
    notIncluded: [
      'USCIS government fees (~$1,440+ for I-485)',
      'DOL PERM posting costs',
      'Employer recruitment costs',
    ],
  },
  {
    title: 'Employment-Based Petition (EB-1, EB-2, EB-3)',
    price: '$8,500 – $12,000',
    note: 'Depending On Complexity And Documentation Needs',
    included: [
      'Full eligibility assessment across all EB categories',
      'NIW self-petition analysis',
      'I-140 petition preparation with full evidence package',
      'Expert opinion letters coordination (EB-1/NIW)',
      'RFE response included',
      'Priority date strategy across preference categories',
    ],
    notIncluded: [
      'USCIS I-140 fee ($715)',
      'Premium processing ($2,805 if desired)',
      'Expert letter professional fees',
    ],
  },
  {
    title: 'Special Immigrant & Humanitarian Green Card (VAWA, U Visa, Asylum)',
    price: '$5,500 – $8,500',
    note: 'Attorney Fee',
    included: [
      'Full humanitarian pathway analysis',
      'VAWA self-petition or U visa certification coordination',
      'Asylum-based adjustment of status',
      'Confidentiality protections throughout',
      'Waiver preparation if needed',
      'Full case monitoring through approval',
    ],
    notIncluded: [
      'USCIS filing fees (many humanitarian cases are fee-exempt)',
      'Translation costs',
    ],
  },
  {
    title: 'Removal Of Conditional Residence (I-751)',
    price: '$5,000 – $5,500',
    note: 'Attorney Fee',
    included: [
      'Joint petition or waiver of joint filing',
      'Comprehensive evidence of bona fide marriage',
      'RFE response if issued',
      'Interview preparation if scheduled',
      'Case monitoring through approval',
    ],
    notIncluded: [
      'USCIS I-751 filing fee ($750)',
      'Biometrics fee (if charged)',
    ],
  },
];

const addOns = [
  { name: 'Premium Processing', price: '$2,805 government fee', body: '15-day processing guarantee for eligible petitions (I-140, certain I-130 cases)' },
  { name: 'Additional RFE Response', price: '$1,500 – $3,000', body: 'Per response for complex Requests for Evidence beyond the first included response' },
  { name: 'Expedite Request Support', price: '$500', body: 'Preparation and submission of USCIS expedite requests with documented justification' },
  { name: 'Certified Translation Services', price: 'Varies by document', body: 'USCIS-compliant certified translations for all non-English documents' },
  { name: 'Credential Evaluations (Employment-Based)', price: '$150 – $350', body: 'Foreign degree equivalency evaluations required for EB-2 and EB-3 petitions' },
  { name: 'Expert Opinion Letters (EB-1 & NIW)', price: '$500 – $2,000 per expert', body: 'Coordination with recognized experts to support extraordinary ability or national interest claims' },
];

const paymentOptions = [
  { label: 'Payment Plans Available', sub: 'Split over 2–4 installments' },
  { label: 'Family Payment Consultation', sub: 'Multi-member case discounts' },
  { label: 'Sliding Scale For Hardship', sub: 'Income-based fee adjustments' },
  { label: 'Delayed Client Flexibility', sub: 'Start now, pay as the case progresses' },
  { label: 'Major Credit Cards', sub: 'Visa, Mastercard, Amex, Discover' },
  { label: 'Payment Plan Contracts', sub: 'Formal installment agreements' },
  { label: 'Cash Payments Accepted', sub: 'With receipt provided' },
];

const resources = [
  { title: 'Complete Green Card Guide (50 Pages)', body: 'Everything you need to understand all green card categories, timelines, and government requirements.', cta: 'Download PDF' },
  { title: 'Green Card Pathways Explained', body: '30-minute video series covering family, employment, and humanitarian green card pathways.', cta: 'Watch Now' },
  { title: 'Priority Date Tracker', body: 'Stay on top of priority dates and visa bulletin updates for your specific EB category.', cta: 'View Tracker' },
  { title: 'I-601 Waiver Success Guide', body: 'How to document extreme hardship cases with professional guidance for maximum approval chances.', cta: 'Download Guide' },
  { title: 'USCIS Interview Masterclass', body: 'What to expect and how to prepare for your green card interview at USCIS or a U.S. consulate.', cta: 'Watch Now' },
  { title: 'Document Checklist Generator', body: 'Generate a detailed document checklist based on your specific green card category and situation.', cta: 'Generate My Checklist' },
];

const faqs = [
  {
    q: 'What exactly is a green card?',
    a: 'A green card gives you lawful permanent residence in the United States, allowing you to live permanently, work for any employer, travel freely, and apply for citizenship after 3–5 years.',
  },
  {
    q: 'What are the main ways to get a green card?',
    a: 'Four primary pathways: Family-based, Employment-based (EB-1 through EB-4), Humanitarian (asylee, refugee, VAWA, U visa, T visa), and Special categories.',
  },
  {
    q: 'How long does it take to get a green card?',
    a: 'Processing times vary: 12–36 months for immediate relatives, 2–5 years for employment-based, and 5–25 years for some family preference categories depending on country of birth.',
  },
  {
    q: "Can I get a green card if I'm in the US illegally?",
    a: 'Sometimes yes. Immediate relatives of US citizens can adjust status in the US even if they entered illegally or overstayed. Others may need waivers. We analyze every situation individually.',
  },
  {
    q: 'What if I have a criminal record?',
    a: 'Some crimes bar green cards, but waivers exist for most grounds. Our waiver approval rate is over 85%. We always assess criminal history before advising whether to proceed.',
  },
];
---

<BaseLayout
  title={`Green Card / Permanent Residence | ${brand.firmName}`}
  description={`Every green card pathway — family, employment, humanitarian, and special categories. Attorney Calvin Pierre helps immigrants secure permanent residence with strategic, comprehensive representation. Free consultation.`}
>

  <!-- ── Hero ── -->
  <section class="section section-dark page-hero gc-hero">
    <div class="container gc-hero-inner">
      <div class="gc-hero-copy">
        <h1>Make America <span class="gc-gold">Your Permanent Home</span></h1>
        <p class="gc-hero-sub">Your green card is more than a document — it is your foundation for building a life in America. Attorney Calvin Pierre, a proud son of Haitian immigrants who secured their own green cards, focuses on helping immigrants navigate compliance with immigration laws, build families, and build careers.</p>
        <div class="gc-hero-actions">
          <a class="btn btn-whatsapp gc-btn" href={brand.whatsappHref} target="_blank" rel="noopener">
            <MessageCircle size={16} stroke-width={2} />
            Discover Your Green Card Path on WhatsApp
          </a>
          <a class="btn btn-primary gc-btn" href="/book-now/">
            <Sparkles size={16} stroke-width={2} />
            Schedule Strategy Session
          </a>
        </div>
      </div>
      <div class="gc-trust-row">
        {[
          { label: '4.9/5 Rating', sub: '150+ Google Reviews', Icon: Star },
          { label: 'All Green Card Categories', sub: 'Family, Employment, Humanitarian, Special', Icon: BadgeCheck },
          { label: '91%+ Approval Rate', sub: 'Across all green card categories', Icon: ShieldCheck },
          { label: 'Expert Guidance', sub: 'Strategic planning from day one', Icon: Lightbulb },
        ].map(({ label, sub, Icon }) => (
          <div class="gc-trust-badge">
            <Icon size={20} stroke-width={1.6} class="gc-trust-icon" />
            <div>
              <strong>{label}</strong>
              <span>{sub}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Body + Key Points ── -->
  <section class="section gc-body-section watermark-section">
    <div class="container gc-body-grid">
      <article class="gc-body-article">
        <h2>The Ultimate Green Card Guide: Expert Strategy &amp; Success</h2>
        <p class="gc-lead">A green card transforms everything. It is the difference between living in uncertainty and building a permanent future. With a green card, you can work anywhere, buy anywhere, travel freely, and eventually become a U.S. citizen. It is the foundation that the American dream is built on — not just for you, but for generations of your family to come.</p>
        <p>There are multiple pathways to a green card. You might qualify through family sponsorship, employment, asylum, special immigrant categories, registry, or even through marriage. The key is understanding which pathways you qualify for and which strategy is optimal for your unique situation — and that is exactly what we do.</p>
        <p>Attorney Calvin Pierre knows the green card journey personally. He parents navigated this same system, earning their permanent residence and building the life that gave him this calling. He carries their experience — and massive legal expertise. He has helped over 1,000 clients navigate the green card process through every pathway — exploring all options, addressing special immigrant categories, registry, inadmissibility, waivers, and especially the complicated cases that most attorneys won't touch.</p>
        <p>The green card process can take months or years depending on your pathway, your employer and your employer-specific handling, your country of origin, and the specific forms you are filing. EB-32 months for immediate relatives, or multiple decades of patience if your country is on a backlog. The time between I-140 approval and I-485 filing depends on your employer and country-specific timeline. We don't see those delays as problems — we see them as opportunities. We use every day in the process to strengthen your case.</p>
        <p>What most people don't realize: the process is complex, mistakes are costly, and having experienced guidance makes all the difference. A single form error can delay your case by months. Missing a deadline can restart the entire process. Filing in the wrong category can cost years. We ensure every application is prepared perfectly. Failing to address properly can shut down your case permanently. Failing to address problems early means bigger complications later.</p>
        <p>We don't just fill out forms — we develop comprehensive strategies. We analyze your immigration history, identify and explore every possible pathway, position you for the strongest possible application, and navigate complications proactively. We prepare special immigrant strategies, prepare waivers, and position your case against challenges before they arise.</p>
      </article>
      <aside class="gc-key-points">
        <h3>Key Points</h3>
        <ul>
          {keyPoints.map(({ text }) => (
            <li>
              <CheckCircle2 size={16} stroke-width={2} />
              <span>{text}</span>
            </li>
          ))}
        </ul>
        <a class="gc-key-cta" href={brand.whatsappHref} target="_blank" rel="noopener">
          Ask About Your Green Card Options
          <ArrowRight size={13} stroke-width={2} />
        </a>
      </aside>
    </div>
  </section>

  <!-- ── Step-by-step process ── -->
  <section class="section gc-steps-section">
    <div class="container gc-steps-head">
      <span class="gc-eyebrow">
        <FileText size={16} stroke-width={1.8} />
        Step-By-Step Process
        <FileText size={16} stroke-width={1.8} />
      </span>
      <h2>Your Pathway To Permanent Residence: <span class="gc-gold">A Strategic Journey</span></h2>
      <p>Every person's journey is unique. Unlike other attorneys who try to have one fee for one package, we start with a comprehensive analysis to identify the best route for your specific situation — maximizing efficiency and minimizing timelines.</p>
    </div>
    <div class="container gc-steps-list">
      {steps.map((step) => (
        <details class="gc-step" name="gc-steps">
          <summary>
            <span class="gc-step-num">{step.number}</span>
            <span class="gc-step-title">{step.title}</span>
            <span class="gc-step-icon" aria-hidden="true"><Plus size={19} stroke-width={1.75} /></span>
          </summary>
          <div class="gc-step-body"><p>{step.body}</p></div>
        </details>
      ))}
    </div>
  </section>

  <!-- ── Testimonials ── -->
  <section class="section gc-stories-section">
    <div class="container">
      <div class="gc-stories-head">
        <span class="gc-eyebrow">
          <BadgeCheck size={16} stroke-width={1.8} />
          Real Success Stories
          <BadgeCheck size={16} stroke-width={1.8} />
        </span>
        <h2>From Temporary To Permanent: <span class="gc-gold">Real Green Card Success Stories</span></h2>
        <p>We have secured more family members professional lives. Many dreams of career advancement became reality. These stories showcase the courage and steady focus that success requires — achieved by real people in real hard cases.</p>
      </div>
      <div class="gc-stories-grid">
        {stories.map((story) => (
          <article class="gc-story-card">
            <div class="gc-story-stars" aria-label={`${story.stars} out of 5 stars`}>
              {Array.from({ length: 5 }, (_, i) =>
                i < story.stars
                  ? <Star size={14} fill="currentColor" stroke-width={0} />
                  : <Star size={14} stroke-width={1.6} />
              )}
            </div>
            <p class="gc-story-text">"{story.text}"</p>
            <footer>
              <strong>{story.name}</strong>
              <span>{story.category}</span>
            </footer>
          </article>
        ))}
      </div>
      <p class="gc-disclaimer">Past results do not guarantee a future outcome. Every case is different.</p>
    </div>
  </section>

  <!-- ── Common Challenges ── -->
  <section class="section gc-challenges-section">
    <div class="container gc-challenges-head">
      <span class="gc-eyebrow gc-eyebrow--sm">Common Challenges</span>
      <h2>Green Card Obstacles We Help <span class="gc-gold">You Overcome</span></h2>
      <p>This path we pave is rarely simple — violations, fees, limits, financial requirements, and documentation challenges affect many applicants. We have seen every complication and know how to solve them.</p>
    </div>
    <div class="container gc-challenges-list">
      {challenges.map((c) => (
        <article class="gc-challenge-card">
          <div class="gc-challenge-header">
            <span class="gc-challenge-label">Challenge #{c.number}</span>
            <h3>{c.title}</h3>
          </div>
          <div class="gc-challenge-cols">
            <div class="gc-challenge-col gc-col-problem">
              <span class="gc-col-label gc-label-problem">The Problem</span>
              <p>{c.problem}</p>
            </div>
            <div class="gc-challenge-col gc-col-solution">
              <span class="gc-col-label gc-label-solution">Our Solution</span>
              <p>{c.solution}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
    <div class="container gc-flat-fee-banner">
      <Wallet size={20} stroke-width={1.8} />
      <div>
        <strong>Flat Fee Guarantee</strong>
        <span>The price we quote is the price you pay. No surprise bills. Payment plans available.</span>
      </div>
    </div>
  </section>

  <!-- ── Pricing ── -->
  <section class="section gc-pricing-section">
    <div class="container gc-pricing-head">
      <h2>Strategic Green Card Planning: <span class="gc-gold">Minimize Fees &amp; Flexible Payments</span></h2>
      <p>Costs and costs vary dramatically in complexity, so our pricing reflects the specific work required for your pathway. We provide transparent, flat-fee pricing after we understand your case. Payment plans are available for all categories. All fees are outlined in detailed written agreements before you commit. We also help you understand government fees precisely — and how to minimize them through fee waivers when you qualify.</p>
    </div>
    <div class="container gc-pricing-grid">
      {pricingCards.map((card) => (
        <article class="gc-price-card">
          <h3>{card.title}</h3>
          <div class="gc-price-amount">{card.price}</div>
          <div class="gc-price-note">{card.note} — Attorney Fee</div>
          <div class="gc-price-included">
            <p class="gc-price-section-label">What's Included</p>
            <ul>
              {card.included.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="gc-price-excluded">
            <p class="gc-price-section-label">What's Not Included</p>
            <ul>
