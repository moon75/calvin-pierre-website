---
import {
  ArrowRight,
  BadgeCheck,
  CalendarCheck,
  FileText,
  Gavel,
  Plane,
  ShieldCheck,
} from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { assets, brand } from '../../data/site';

const practiceAreas = [
  {
    title: 'Asylum',
    slug: 'asylum',
    Icon: ShieldCheck,
    image: assets.asylum,
    description:
      'We help individuals fleeing persecution find safety in the United States. Our team prepares strong applications and represents clients in hearings to ensure their voices are heard.',
  },
  {
    title: 'Bond Hearings',
    slug: 'bond-hearings',
    Icon: Gavel,
    image: assets.bond,
    description:
      'If you or a loved one is detained, we act quickly to request a bond hearing. We fight for your release and work to protect your rights while your immigration case is pending.',
  },
  {
    title: 'Citizenship',
    slug: 'citizenship',
    Icon: BadgeCheck,
    image: assets.citizenship,
    description:
      'Becoming a U.S. citizen is a life-changing milestone. We guide you through the naturalization process, from filing the N-400 application to preparing for your interview and exam.',
  },
  {
    title: 'Appeals',
    slug: 'appeals',
    Icon: FileText,
    image: assets.appeals,
    description:
      "A denial doesn't have to be the end. We review your case, identify legal errors, and file strong appeals to give you another chance at success.",
  },
  {
    title: 'Visas',
    slug: 'visas',
    Icon: Plane,
    image: assets.visas,
    description:
      'From family-based and employment visas to humanitarian relief, we help you navigate the complex U.S. visa system with strategic guidance and careful documentation at every step.',
  },
];
---

<BaseLayout
  title={`Practice Areas | ${brand.firmName}`}
  description="Immigration practice areas at Pierre Vanguard Law — asylum, bond hearings, citizenship, appeals, visas, and full-service representation."
>
  <section class="pa-hero">
    <div class="pa-hero-bg" aria-hidden="true">
      <img src={assets.team} alt="" loading="eager" />
    </div>
    <div class="container pa-hero-content">
      <h1>Practice Areas</h1>
      <div class="pa-hero-rule" aria-hidden="true"></div>
      <p class="pa-hero-sub">{brand.attorneyName} — Full Service Immigration Attorney</p>
      <a class="pa-hero-cta" href="/book-now/">
        <CalendarCheck size={16} stroke-width={2} />
        <span>Book Your Appointment Online</span>
      </a>
    </div>
  </section>

  <section class="pa-areas">
    <div class="container">
      <div class="pa-grid">
        {practiceAreas.map((area, index) => (
          <article class={`pa-card ${index === practiceAreas.length - 1 && practiceAreas.length % 2 === 1 ? 'pa-card-last' : ''}`}>
            <div class="pa-card-info">
              <div class="pa-icon">
                <area.Icon size={26} stroke-width={1.5} />
              </div>
              <h2>{area.title}</h2>
              <p>{area.description}</p>
              <a class="pa-card-link" href={`/practice-areas/${area.slug}/`}>
                Learn more <ArrowRight size={14} stroke-width={2} />
              </a>
            </div>
            <div class="pa-card-media">
              <img src={area.image} alt="" loading="lazy" />
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .pa-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(96px, 12vw, 160px) 0 clamp(80px, 10vw, 130px);
    color: #ffffff;
    background: var(--color-night);
  }

  .pa-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .pa-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.22;
    filter: saturate(0.72) contrast(1.05);
  }

  .pa-hero-bg::after {
    position: absolute;
    inset: 0;
    content: "";
    background:
      linear-gradient(180deg, rgba(4, 14, 32, 0.92) 0%, rgba(4, 14, 32, 0.78) 50%, rgba(4, 14, 32, 0.94) 100%),
      radial-gradient(circle at 50% 14%, rgba(201, 171, 105, 0.18), transparent 36%);
  }

  .pa-hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .pa-hero-content h1 {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(2.6rem, 5.4vw, 4.4rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .pa-hero-rule {
    width: 88px;
    height: 2px;
    margin: 26px 0 22px;
    background: var(--color-gold);
  }

  .pa-hero-sub {
    margin: 0 0 36px;
    color: var(--color-gold);
    font-family: var(--font-sans);
    font-size: clamp(0.86rem, 1vw, 1rem);
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
  }

  .pa-hero-cta {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    padding: 16px 28px;
    color: #ffffff;
    background: linear-gradient(135deg, var(--color-gold) 0%, #b89250 100%);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    box-shadow: 0 18px 38px rgba(201, 171, 105, 0.32);
    transition: transform 200ms ease, box-shadow 200ms ease, filter 200ms ease;
  }

  .pa-hero-cta:hover {
    color: #ffffff;
    transform: translateY(-2px);
    box-shadow: 0 24px 52px rgba(201, 171, 105, 0.42);
    filter: brightness(1.04);
  }

  .pa-areas {
    padding: clamp(72px, 9vw, 120px) 0;
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 14%, rgba(201, 171, 105, 0.1), transparent 32%),
      linear-gradient(180deg, #061227 0%, #04102a 100%);
  }

  .pa-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(28px, 3.2vw, 44px);
  }

  .pa-card {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
      rgba(8, 24, 56, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.3);
    transition: transform 240ms ease, box-shadow 240ms ease, border-color 240ms ease;
  }

  .pa-card::before {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    content: "";
    background: linear-gradient(90deg, var(--color-gold), rgba(201, 171, 105, 0));
    opacity: 0;
    transition: opacity 240ms ease;
  }

  .pa-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 28px 60px rgba(0, 0, 0, 0.5);
    border-color: rgba(201, 171, 105, 0.4);
  }

  .pa-card:hover::before {
    opacity: 1;
  }

  .pa-card-last {
    grid-column: 1 / -1;
    max-width: calc(50% - clamp(14px, 1.6vw, 22px));
    margin-inline: auto;
  }

  .pa-card-info {
    display: grid;
    align-content: start;
    gap: 14px;
    padding: clamp(26px, 2.8vw, 36px);
  }

  .pa-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    margin-bottom: 4px;
    border-radius: 12px;
    background: rgba(201, 171, 105, 0.12);
    color: var(--color-gold);
  }

  .pa-card-info h2 {
    margin: 0;
    color: var(--color-gold);
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 1.95vw, 1.85rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: 0;
  }

  .pa-card-info p {
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-sans);
    font-size: 0.94rem;
    font-weight: 500;
    line-height: 1.7;
  }

  .pa-card-link {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    margin-top: 10px;
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    transition: color 200ms ease, gap 200ms ease;
  }

  .pa-card-link svg {
    transition: transform 200ms ease;
  }

  .pa-card-link:hover {
    color: var(--color-gold);
  }

  .pa-card-link:hover svg {
    transform: translateX(4px);
  }

  .pa-card-media {
    position: relative;
    overflow: hidden;
    min-height: 240px;
  }

  .pa-card-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .pa-card:hover .pa-card-media img {
    transform: scale(1.04);
  }

  @media (max-width: 980px) {
    .pa-grid {
      grid-template-columns: 1fr;
    }

    .pa-card-last {
      max-width: 100%;
      grid-column: auto;
    }
  }

  @media (max-width: 560px) {
    .pa-card {
      grid-template-columns: 1fr;
    }

    .pa-card-media {
      order: -1;
      min-height: 200px;
    }
  }
</style>
