    color: var(--color-gold) !important;
    font-size: 0.84rem !important;
  }

  .tps-step-timeline em { font-style: normal; }

  /* ── Stories ── */
  .tps-stories-section {
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 90%, rgba(201, 171, 105, 0.08), transparent 32%),
      linear-gradient(180deg, #061227 0%, #04102a 100%);
  }

  .tps-stories-head {
    display: grid;
    gap: 16px;
    justify-items: center;
    max-width: 720px;
    margin: 0 auto 48px;
    text-align: center;
  }

  .tps-stories-head h2 {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.4vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: 0.2px;
    text-transform: uppercase;
  }

  .tps-stories-head p {
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 1rem;
    line-height: 1.65;
  }

  .tps-stories-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .tps-story-card {
    position: relative;
    display: grid;
    gap: 12px;
    align-content: start;
    padding: 30px 26px 24px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    transition: background 220ms ease, border-color 220ms ease, transform 220ms ease;
  }

  .tps-story-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(201, 171, 105, 0.4);
    transform: translateY(-3px);
  }

  /* Last 2 cards centred on the third row */
  .tps-story-card:nth-child(4) {
    grid-column: 1 / 2;
  }

  .tps-stories-grid:has(.tps-story-card:nth-child(5):last-child) {
    grid-template-columns: repeat(6, minmax(0, 1fr));
  }

  .tps-stories-grid:has(.tps-story-card:nth-child(5):last-child) .tps-story-card:nth-child(1) { grid-column: span 2; }
  .tps-stories-grid:has(.tps-story-card:nth-child(5):last-child) .tps-story-card:nth-child(2) { grid-column: span 2; }
  .tps-stories-grid:has(.tps-story-card:nth-child(5):last-child) .tps-story-card:nth-child(3) { grid-column: span 2; }
  .tps-stories-grid:has(.tps-story-card:nth-child(5):last-child) .tps-story-card:nth-child(4) { grid-column: 2 / span 2; }
  .tps-stories-grid:has(.tps-story-card:nth-child(5):last-child) .tps-story-card:nth-child(5) { grid-column: span 2; }

  .tps-story-quote {
    color: var(--color-gold);
    opacity: 0.4;
  }

  .tps-story-stars {
    display: inline-flex;
    gap: 3px;
    color: var(--color-gold);
  }

  .tps-story-title {
    margin: 2px 0 0;
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .tps-story-card > p {
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .tps-story-card footer {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: 10px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .tps-story-card footer strong {
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 700;
  }

  .tps-story-card footer span {
    color: var(--color-gold);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .tps-disclaimer {
    margin: 32px auto 0;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.84rem;
    font-style: italic;
    text-align: center;
  }

  /* ── Final CTA ── */
  .tps-final-cta {
    color: #ffffff;
    text-align: center;
    background:
      radial-gradient(circle at 50% 0%, rgba(201, 171, 105, 0.12), transparent 50%),
      linear-gradient(180deg, #061227 0%, #04102a 100%);
  }

  .tps-final-inner {
    max-width: 820px;
    margin: 0 auto;
  }

  .tps-final-cta h2 {
    margin: 0 0 16px;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.8vw, 3.2rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: 0.3px;
    text-transform: uppercase;
  }

  .tps-final-lead {
    max-width: 600px;
    margin: 0 auto 32px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 1.05rem;
    line-height: 1.55;
  }

  .tps-final-actions {
    margin-bottom: 28px;
  }

  .tps-final-languages {
    margin: 0 0 32px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.9;
  }

  .tps-final-divider {
    height: 1px;
    margin: 0 auto 28px;
    background: linear-gradient(90deg, transparent, rgba(201, 171, 105, 0.4), transparent);
  }

  .tps-final-locations {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    color: var(--color-gold);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.3px;
  }

  .tps-final-locations svg { flex: 0 0 auto; }

  .tps-final-note {
    max-width: 680px;
    margin: 0 auto;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.84rem;
    font-style: italic;
    line-height: 1.65;
  }

  /* ── Responsive ── */
  @media (max-width: 980px) {
    .tps-info-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .tps-stories-grid,
    .tps-stories-grid:has(.tps-story-card:nth-child(5):last-child) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .tps-stories-grid:has(.tps-story-card:nth-child(5):last-child) .tps-story-card,
    .tps-stories-grid:has(.tps-story-card:nth-child(5):last-child) .tps-story-card:nth-child(4),
    .tps-stories-grid:has(.tps-story-card:nth-child(5):last-child) .tps-story-card:nth-child(5) {
      grid-column: span 1;
    }

    .support-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      padding: 36px 0;
    }
  }

  @media (max-width: 680px) {
    .support-grid {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 32px 0;
    }
  }

  @media (max-width: 640px) {
    .tps-hero-actions .btn {
      width: 100%;
      min-width: 0;
    }

    .tps-hero-trust {
      border-radius: 8px;
      padding: 12px 16px;
    }

    .tps-stories-grid,
    .tps-stories-grid:has(.tps-story-card:nth-child(5):last-child) {
      grid-template-columns: 1fr;
    }

    .tps-step-body {
      padding-left: 24px;
    }

    .tps-step-num {
      min-width: 38px;
      height: 38px;
      font-size: 0.82rem;
    }

    .tps-step summary {
      gap: 12px;
      padding: 16px 18px;
    }

    .tps-step-body {
      padding: 0 18px 18px 18px;
    }

    .tps-step-icon {
      width: 32px;
      height: 32px;
    }

    .tps-story-card {
      padding: 22px 18px;
    }

    .support-item {
      padding: 20px 18px;
    }

    .btn-outline-gold {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .tps-stories-head { margin-bottom: 32px; }
    .tps-steps-head { margin-bottom: 32px; }
    .tps-final-languages { font-size: 0.82rem; }
  }

  /* ── CTA Banner ── */
  .tps-cta-banner {
    padding: 56px 0;
    color: #ffffff;
    background: #071528;
    text-align: center;
  }

  .tps-cta-banner-inner {
    display: grid;
    gap: 28px;
    justify-items: center;
    max-width: 780px;
    margin: 0 auto;
  }

  .tps-cta-banner-inner p {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 2.4vw, 1.75rem);
    font-weight: 700;
    line-height: 1.45;
  }

  .tps-cta-banner-accent {
    color: var(--color-gold);
  }

  .tps-cta-banner-btn {
    gap: 10px;
    min-height: 54px;
    padding: 0 32px;
    font-size: 0.9rem;
  }

  @media (max-width: 640px) {
    .tps-cta-banner-btn {
      width: 100%;
      justify-content: center;
    }
  }

  /* ── Pricing section ── */
  .tps-pricing-section {
    background:
      radial-gradient(circle at 50% 0%, rgba(201, 171, 105, 0.08), transparent 50%),
      linear-gradient(180deg, #04102a 0%, #061227 100%);
    color: #ffffff;
  }

  .tps-guarantee-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 10px 20px;
    background: rgba(34, 197, 94, 0.08);
    border: 1px solid rgba(34, 197, 94, 0.35);
    border-radius: 999px;
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: 0.84rem;
    max-width: fit-content;
    margin: 0 auto 32px;
  }

  .tps-guarantee-badge svg {
    color: #22c55e;
    flex-shrink: 0;
  }

  .tps-guarantee-badge strong {
    font-weight: 800;
    margin-right: 4px;
    color: #ffffff;
  }

  .tps-guarantee-badge span {
    color: rgba(255, 255, 255, 0.7);
  }

  .tps-pricing-head {
    text-align: center;
    max-width: 820px;
    margin: 0 auto 44px;
    display: grid;
    gap: 14px;
  }

  .tps-pricing-head h2 {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 3.2vw, 2.8rem);
    font-weight: 700;
    line-height: 1.1;
  }

  .tps-pricing-accent {
    color: var(--color-gold);
  }

  .tps-pricing-head p {
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.98rem;
    line-height: 1.72;
  }

  /* Cards */
  .tps-pricing-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 48px;
  }

  .tps-price-card {
    position: relative;
    display: grid;
    gap: 14px;
    align-content: start;
    padding: 26px 22px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-top: 3px solid rgba(255, 255, 255, 0.15);
    transition: transform 200ms ease, border-color 200ms ease;
  }

  .tps-price-card:hover {
    transform: translateY(-4px);
    border-color: rgba(201, 171, 105, 0.4);
  }

  .tps-price-card--featured {
    border-top-color: var(--color-gold);
    background: rgba(201, 171, 105, 0.07);
  }

  .tps-price-featured-tag {
    display: inline-block;
    align-self: start;
    padding: 4px 12px;
    background: var(--color-gold);
    color: #0a1f44;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    border-radius: 2px;
  }

  .tps-price-card h3 {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: 1.08rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .tps-price-amount {
    color: var(--color-gold);
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .tps-price-amount span {
    display: block;
    color: rgba(255, 255, 255, 0.55);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
  }

  .tps-price-sub {
    margin-top: -8px;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.8rem;
    text-decoration: line-through;
  }

  .tps-price-list {
    display: grid;
    gap: 7px;
    padding: 14px 0 0;
    margin: 6px 0 0;
    list-style: none;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .tps-price-list li {
    position: relative;
    padding-left: 18px;
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.84rem;
    line-height: 1.5;
  }

  .tps-price-list li::before {
    position: absolute;
    left: 0;
    top: 7px;
    width: 10px;
    height: 6px;
    content: "";
    border-left: 2px solid var(--color-gold);
    border-bottom: 2px solid var(--color-gold);
    transform: rotate(-45deg);
  }

  /* Add-ons */
  .tps-addons {
    margin-bottom: 40px;
  }

  .tps-addons h3 {
    margin: 0 0 16px;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    text-align: center;
  }

  .tps-addons-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .tps-addon-card {
    display: grid;
    gap: 6px;
    padding: 18px 16px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
    transition: border-color 180ms ease;
  }

  .tps-addon-card:hover {
    border-color: rgba(201, 171, 105, 0.4);
  }

  .tps-addon-card strong {
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .tps-addon-card span {
    color: var(--color-gold);
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 700;
  }

  /* Gov fees + fee waiver */
  .tps-fees-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    gap: 20px;
    margin-bottom: 40px;
  }

  .tps-gov-fees,
  .tps-fee-waiver {
    padding: 26px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .tps-gov-fees h3,
  .tps-fee-waiver .tps-fee-waiver-header {
    margin: 0 0 16px;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 700;
  }

  .tps-gov-fees h3 em {
    font-size: 0.82rem;
    font-style: normal;
    color: rgba(255, 255, 255, 0.45);
    font-family: var(--font-sans);
    font-weight: 500;
  }

  .tps-fee-waiver-header {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tps-fee-waiver-header svg {
    color: #22c55e;
    flex-shrink: 0;
  }

  .tps-gov-fees ul {
    display: grid;
    gap: 0;
    padding: 0;
    margin: 0;
    list-style: none;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .tps-gov-fees li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 0.9rem;
  }

  .tps-gov-fees li:last-child { border-bottom: 0; }

  .tps-gov-fees li span { color: rgba(255, 255, 255, 0.65); }
  .tps-gov-fees li strong { color: #ffffff; font-weight: 700; }

  .tps-fees-total {
    background: rgba(201, 171, 105, 0.1);
  }

  .tps-fees-total span { color: #ffffff !important; font-weight: 700; }

  .tps-fee-waiver p {
    margin: 0 0 10px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .tps-poverty-label {
    color: #ffffff !important;
    font-weight: 700 !important;
    margin-bottom: 8px !important;
  }

  .tps-poverty-list {
    display: grid;
    gap: 0;
    padding: 0;
    margin: 0 0 12px;
    list-style: none;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .tps-poverty-list li {
    display: flex;
    justify-content: space-between;
    padding: 8px 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 0.88rem;
  }

  .tps-poverty-list li:last-child { border-bottom: 0; }
  .tps-poverty-list span { color: rgba(255, 255, 255, 0.65); }
  .tps-poverty-list strong { color: #ffffff; font-weight: 700; }

  .tps-waiver-rate {
    color: rgba(255, 255, 255, 0.85) !important;
    font-size: 0.9rem !important;
    font-weight: 600;
  }

  .tps-waiver-rate strong { color: #22c55e; }

  /* Payment bar */
  .tps-payment-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #ffffff;
  }

  .tps-payment-bar span {
    padding: 16px 28px;
    font-family: var(--font-sans);
    font-size: 0.86rem;
    font-weight: 700;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    white-space: nowrap;
  }

  .tps-payment-bar span:last-child { border-right: 0; }

  /* Pricing responsive */
  @media (max-width: 1100px) {
    .tps-pricing-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .tps-addons-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .tps-pricing-grid {
      grid-template-columns: 1fr;
    }

    .tps-addons-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .tps-fees-grid {
      grid-template-columns: 1fr;
    }

    .tps-payment-bar span {
      flex: 1 1 calc(50% - 1px);
      border-right: 1px solid rgba(255,255,255,0.12);
      border-bottom: 1px solid rgba(255,255,255,0.12);
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .tps-addons-grid { grid-template-columns: 1fr; }
    .tps-payment-bar span { flex: 1 1 100%; border-right: 0; }
  }

  /* ── Refund Guarantee Banner ── */
  .tps-refund-banner {
    padding: 36px 0 32px;
    color: #ffffff;
    background: #071528;
    text-align: center;
  }

  .tps-refund-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    text-align: left;
  }

  .tps-refund-icon { color: var(--color-gold); flex-shrink: 0; }

  .tps-refund-inner div {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: baseline;
  }

  .tps-refund-inner strong {
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 800;
  }

  .tps-refund-inner span {
    color: rgba(255,255,255,0.7);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .tps-refund-btn {
    gap: 10px;
    min-height: 50px;
    padding: 0 26px;
    font-size: 0.84rem;
  }

  /* ── Q&A Accordion Section ── */
  .tps-qanda-section {
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 50%, rgba(201,171,105,0.07), transparent 36%),
      linear-gradient(180deg, #04102a 0%, #061227 100%);
  }

  .tps-qanda-head {
    display: grid;
    gap: 16px;
    justify-items: center;
    max-width: 820px;
    margin: 0 auto 36px;
    text-align: center;
  }

  .tps-qanda-head h2 {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-serif);
    font-size: clamp(1.95rem, 3.2vw, 2.9rem);
    font-weight: 700;
    line-height: 1.1;
  }

  .tps-qanda-head p {
    margin: 0;
    color: rgba(255,255,255,0.7);
    font-size: 1rem;
    line-height: 1.7;
  }

  .tps-qanda-list {
    display: grid;
    gap: 8px;
    max-width: 860px;
    margin: 0 auto;
  }

  .tps-qa-item {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    transition: background 200ms ease, border-color 200ms ease;
  }

  .tps-qa-item[open] {
    background: rgba(201,171,105,0.08);
    border-color: rgba(201,171,105,0.4);
  }

  .tps-qa-item summary {
    display: grid;
    grid-template-columns: auto minmax(0,1fr) auto;
    gap: 14px;
    align-items: center;
    padding: 16px 20px;
