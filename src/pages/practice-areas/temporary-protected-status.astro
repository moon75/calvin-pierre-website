---
import {
  ArrowRight,
  BadgeCheck,
  Briefcase,
  CheckCircle2,
  Clock,
  FileText,
  Globe,
  Lightbulb,
  MapPin,
  MessageCircle,
  MessageSquare,
  Phone,
  Plus,
  Quote,
  RefreshCw,
  ShieldCheck,
  Star,
} from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { brand } from '../../data/site';

const tpsResults = [
  { text: 'Protection from deportation — TPS shields you from removal while your country is designated' },
  { text: 'Work authorization — legal right to work for any employer anywhere in the US' },
  { text: 'Employer documentation — we work with both employees and employers on proper paperwork' },
  { text: 'Travel authorization — may be eligible to travel internationally with Advance Parole' },
  { text: 'Path to permanent residence — in some cases, TPS can be a stepping stone to a green card' },
  { text: "Driver's license — most states issue licenses to TPS holders with valid work permits" },
  { text: 'Advance Parole — apply to visit family abroad without losing your TPS status' },
  { text: 'Education and benefits — confirm eligibility for state healthcare, education, and aid programs' },
];

const trustBand = [
  {
    title: '4.9 Rating',
    text: '150+ five-star Google reviews from TPS clients across Haiti, Honduras, Venezuela, El Salvador, and beyond.',
    Icon: Star,
  },
  {
    title: 'Haïti TPS Report',
    text: 'Deep expertise in Haiti TPS designations, re-registrations, and the pathway from TPS to permanent residence.',
    Icon: FileText,
  },
  {
    title: 'Emergency Response',
    text: '24/7 intake for urgent TPS filings, missed deadlines, and USCIS Requests for Evidence.',
    Icon: ShieldCheck,
  },
  {
    title: 'Multilingual Support',
    text: 'We speak English, Haitian Creole, Spanish, and French — serving our entire TPS community.',
    Icon: MessageSquare,
  },
];

const steps = [
  {
    number: '01',
    title: 'Urgent Eligibility Assessment',
    timeline: 'Within 24 hours of contact',
    body: 'We immediately verify your country of origin, arrival date, continuous residence, and any factors that could affect eligibility — criminal history, prior removal orders, or missed registration windows. Many people assume they don\'t qualify when they actually do. We check everything.',
  },
  {
    number: '02',
    title: 'Document Collection & Evidence Gathering',
    timeline: '1–2 weeks',
    body: 'We provide a personalized document checklist covering identity, nationality, and continuous residence. If traditional records are unavailable, we build your case with alternative evidence — utility bills, employer letters, school records, medical documents, affidavits from community members, and church records.',
  },
  {
    number: '03',
    title: 'Form I-821 Preparation & Filing',
    timeline: 'Filed within days of document completion',
    body: 'We prepare and file Form I-821 (TPS Application) and Form I-765 (Employment Authorization) simultaneously so you receive both protections at once. Every form is reviewed for accuracy before submission. We also file Form I-131 for Advance Parole when travel is needed.',
  },
  {
    number: '04',
    title: 'Biometrics Appointment',
    timeline: 'Scheduled by USCIS after filing (typically 4–8 weeks)',
    body: 'After filing, USCIS schedules your biometrics (fingerprinting and photo) appointment at a local Application Support Center. We prepare you for what to expect, confirm your appointment details, and resolve any scheduling issues. We monitor your case status throughout.',
  },
  {
    number: '05',
    title: 'USCIS Processing & Approval',
    timeline: '3–6 months (varies by country and USCIS workload)',
    body: 'USCIS reviews your application and either approves or issues a Request for Evidence (RFE). We respond to all RFEs immediately with comprehensive additional documentation and legal arguments. If approved, you receive your TPS approval notice and Employment Authorization Document (EAD card).',
  },
  {
    number: '06',
    title: 'Work Authorization & TPS Benefits',
    timeline: 'Begins upon EAD card receipt',
    body: 'Your EAD allows you to work for any employer in the US, change jobs freely, obtain a driver\'s license in most states, open bank accounts, and access state benefits you are eligible for. We explain all your rights and make sure your employer understands how to properly verify your work authorization.',
  },
  {
    number: '07',
    title: 'Re-Registration & Renewal Monitoring',
    timeline: 'Ongoing — we monitor every USCIS announcement',
    body: 'TPS must be renewed each time your country\'s designation is extended. We track every Federal Register notice and DHS announcement — and we contact you proactively when your re-registration window opens. You will never miss a deadline with us watching.',
  },
];

const stories = [
  {
    title: 'Got My Work Permit In 3 Months',
    name: 'Jean-Paul M.',
    city: 'Newark, NJ',
    stars: 5,
    text: 'Attorney Pierre explained everything to me clearly. I got my work permit in 3 months and I can now support my family legally. He even helped me understand how TPS could lead to something more permanent.',
  },
  {
    title: 'Protected Even Without Papers',
    name: 'María Elena R.',
    city: 'Elizabeth, NJ',
    stars: 5,
    text: '"I thought I had no chance because I came without papers." They helped me figure it out. Now I have TPS, a work permit, and a driver\'s license. I feel safe for the first time in years.',
  },
  {
    title: 'Called From Across Latin America',
    name: 'Carlos R.',
    city: 'Paterson, NJ',
    stars: 5,
    text: 'They called me before I even knew my TPS expiring. Their service is outstanding. They filed my renewal and I never had a gap in my work authorization.',
  },
  {
    title: 'My TPS Saved and Protected Me',
    name: 'Yelissa C.',
    city: 'Union City, NJ',
    stars: 5,
    text: "I heard about TPS from a friend from church. Attorney Pierre took my call immediately, assessed my situation, and filed within the week. That application saved my TPS and protected me.",
  },
  {
    title: 'Our Whole Family Is Now Safe',
    name: 'The Baptiste Family',
    city: 'Irvington, NJ',
    stars: 5,
    text: 'Five applications — all approved. They guided us through the process in Haitian Creole and made sure every family member was protected. Now we are all working legally and planning our next steps.',
  },
];
---

<BaseLayout
  title={`Temporary Protected Status (TPS) | Immigration Help | ${brand.firmName}`}
  description="TPS protection for immigrants from Haiti, Honduras, Venezuela, El Salvador, and more. Attorney Calvin Pierre helps with TPS filings, renewals, work permits, and green card pathways. 24/7 intake."
>
  <!-- ── Hero ── -->
  <section class="section section-dark page-hero tps-hero">
    <div class="container tps-hero-grid">
      <div class="tps-hero-copy">
        <span class="tps-eyebrow">
          <ShieldCheck size={16} stroke-width={1.8} />
          TPS Protection · 24/7 Consultation
          <ShieldCheck size={16} stroke-width={1.8} />
        </span>
        <h1>Protect Your Right To Stay In America With TPS</h1>
        <p>
          Temporary Protected Status can shield you from deportation and give you work
          authorization. As a proud son of Haitian immigrants, Attorney Calvin Pierre has helped
          hundreds of families from TPS-designated countries secure their safety and their future.
        </p>
        <div class="tps-hero-actions">
          <a class="btn btn-whatsapp" href={brand.whatsappHref} target="_blank" rel="noopener">
            <MessageCircle size={16} stroke-width={2} />
            Check Your TPS Eligibility on WhatsApp
          </a>
          <a class="btn btn-primary" href={brand.phoneHref}>
            <Phone size={16} stroke-width={2} />
            Call Now: {brand.phone}
          </a>
        </div>
        <p class="tps-hero-trust">
          <ShieldCheck size={15} stroke-width={2} />
          We've protected hundreds of TPS families from Haiti, Honduras, Venezuela, El Salvador, Ukraine, and more.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Trust band ── -->
  <section class="support-band section-soft watermark-section">
    <div class="container support-grid">
      {trustBand.map(({ title, text, Icon }) => (
        <article class="support-item">
          <div class="support-icon"><Icon size={32} stroke-width={1.55} /></div>
          <div>
            <h2>{title}</h2>
            <p>{text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ── TPS Can Change Everything ── -->
  <section class="section tps-info-section watermark-section">
    <div class="container tps-info-grid">
      <!-- Left: article text -->
      <div class="tps-article">
        <span class="tps-section-label">Why It Matters</span>
        <h2>TPS Can Change Everything For Your Family</h2>

        <p>
          If you're from Haiti, Honduras, Nicaragua, El Salvador, Ukraine, Sudan, or another
          country designated for Temporary Protected Status, you may be eligible for protection
          that can change everything. TPS protects you from deportation, gives you work
          authorization, and allows you to live openly without the constant fear of ICE
          enforcement.
        </p>
        <p>
          But here's what most people don't realize: <strong>TPS has strict deadlines.</strong> Missing your
          registration window can mean losing your only path to legal status. That's why acting
          quickly isn't just important — it's critical.
        </p>
        <p>
          Attorney Calvin Pierre understands TPS both legally and personally. As the son of Haitian
          immigrants, he knows the fear families feel when living in uncertainty. He has helped
          hundreds of families from Haiti, Honduras, and across Latin America and the Caribbean
          navigate TPS applications, re-registrations, and work authorization filings.
        </p>
        <p>
          During your TPS period, you can work legally, get a driver's license, travel
          internationally (with Advance Parole), and in some cases use TPS as a stepping stone
          toward permanent residence. We monitor every TPS announcement or extension made by the
          Department of Homeland Security — and when your country gets redesignated or extended, we
          contact our clients immediately so the process starts without delay.
        </p>
        <a class="btn btn-outline-gold" href={brand.whatsappHref} target="_blank" rel="noopener">
          Check My TPS Eligibility
          <ArrowRight size={16} stroke-width={1.8} />
        </a>
      </div>

      <!-- Right: Key TPS Results -->
      <div class="tps-results-card">
        <div class="tps-results-header">
          <span class="tps-results-label">KEY TPS RESULTS</span>
          <h3>What TPS Does For You</h3>
        </div>
        <ul class="tps-results-list">
          {tpsResults.map(({ text }) => (
            <li>
              <CheckCircle2 size={17} stroke-width={2} />
              <span>{text}</span>
            </li>
          ))}
        </ul>
        <div class="tps-results-cta">
          <p>Don't Wait Until It's Too Late. TPS Registration Periods Are Limited.</p>
          <a class="btn btn-whatsapp tps-results-btn" href={brand.whatsappHref} target="_blank" rel="noopener">
            Get Your Free TPS Consultation on WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Step-by-step process ── -->
  <section class="section tps-steps-section">
    <div class="container tps-steps-head">
      <span class="tps-eyebrow">
        <FileText size={16} stroke-width={1.8} />
        Step-By-Step Process
        <FileText size={16} stroke-width={1.8} />
      </span>
      <h2>Your Path To TPS Protection: Act Fast, Get It Right</h2>
      <p>
        TPS applications require precise documentation and perfect timing. Missing a deadline or
        filing incorrectly can result in denial. Here's how we ensure your application is filed
        correctly and on time.
      </p>
    </div>
    <div class="container tps-steps-list">
      {steps.map((step, index) => (
        <details class="tps-step" name="tps-steps" open={index === 0}>
          <summary>
            <span class="tps-step-num">{step.number}</span>
            <span class="tps-step-title">{step.title}</span>
            <span class="tps-step-icon" aria-hidden="true">
              <Plus size={20} stroke-width={1.75} />
            </span>
          </summary>
          <div class="tps-step-body">
            <p>{step.body}</p>
            <p class="tps-step-timeline">
              <Clock size={14} stroke-width={2} />
              <em>Timeline: {step.timeline}</em>
            </p>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- ── Obstacles ── -->
  <section class="section tps-obstacles-section">
    <div class="container tps-obstacles-head">
      <span class="tps-eyebrow">
        <ShieldCheck size={16} stroke-width={1.8} />
        We've Seen It All
        <ShieldCheck size={16} stroke-width={1.8} />
      </span>
      <h2>TPS Obstacles We Help You <span class="tps-accent">Overcome</span></h2>
      <p>TPS applications can be denied for reasons that seem minor but are devastating — missed deadlines, insufficient evidence, past immigration violations. We've seen every complication and know how to solve them.</p>
    </div>

    <div class="container tps-obstacles-list">
      {[
        {
          title: 'Missed Registration Deadlines',
          problem: 'TPS registration periods are limited — sometimes as few as 60 days. If you missed the initial registration period, you may have assumed your chance was gone. Many people don\'t even know their country had a TPS designation until it\'s too late.',
          solution: 'We actively monitor every U.S. announcement and track deadlines for all designated countries. For current clients, we send reminders up to 60 days before TPS expires. And if you\'ve already missed a deadline — it\'s not always over. We explore alternative pathways including late filing arguments, other immigration remedies, advocating for parole, cancellation of removal, or adjustment of status.',
        },
        {
          title: 'Lack of Documentation',
          problem: 'Many people don\'t have passports, birth certificates, or any proof of continuous residence. Many fled dangerous situations without time to gather documents. Years of records are missing, and most people don\'t know how to build a case without them.',
          solution: 'We specialize in building complete, legally sufficient files using alternative evidence — bank statements, personal letters, financial records, affidavits, children\'s school records, work or community organization letters, and church records. We\'ve successfully obtained TPS approval using alternative documentation for hundreds of clients.',
        },
        {
          title: 'Criminal History or Prior Immigration Violations',
          problem: 'Certain criminal convictions — even minor ones — can create TPS eligibility issues. Multiple misdemeanors, illegal entries, or prior deportation orders can all complicate your application or make it seem impossible.',
          solution: 'We carefully review your full criminal and immigration history to determine what actually affects your eligibility. Simple misdemeanors are sometimes not disqualifying. We identify what matters and what doesn\'t, challenge bars that were applied incorrectly, and structure filings to give you the strongest possible case despite prior issues.',
        },
        {
          title: 'Cost of Application Fees',
          problem: 'USCIS application fees represent a real financial burden. For single parents, large families, and low-income households — the cost of filing for multiple family members can be overwhelming, especially when income is already limited.',
          solution: 'Fee waivers are available for qualified applicants based on demonstrated financial hardship. We review your situation and prepare fee waiver requests where appropriate. We also offer payment plans for attorney fees so that your financial situation never prevents you from getting the legal protection you deserve.',
        },
        {
          title: 'TPS Unavailability & Changing Policies',
          problem: 'TPS designations are political — administrations change, policies shift, and programs can be terminated with little notice. People who have built their lives around TPS status face devastating uncertainty when the program\'s future is unclear.',
          solution: 'When TPS policy changes threaten your status, we help you evaluate all viable immigration alternatives — asylum, cancellation of removal, adjustment of status, U visas, and other pathways you may not know about. We stay ahead of policy changes and proactively contact clients when their status may be affected, so you always have a plan.',
        },
      ].map((item) => (
        <details class="tps-obstacle" name="tps-obstacles">
          <summary>
            <span class="tps-obstacle-title">{item.title}</span>
            <span class="tps-step-icon" aria-hidden="true">
              <Plus size={20} stroke-width={1.75} />
            </span>
          </summary>
          <div class="tps-obstacle-body">
            <div class="tps-obstacle-col">
              <span class="tps-col-label tps-col-problem">The Problem</span>
              <p>{item.problem}</p>
            </div>
            <div class="tps-obstacle-col">
              <span class="tps-col-label tps-col-solution">Our Solution</span>
              <p>{item.solution}</p>
            </div>
          </div>
        </details>
      ))}
    </div>

  </section>

  <!-- ── CTA Banner ── -->
  <section class="tps-cta-banner">
    <div class="container tps-cta-banner-inner">
      <p>
        TPS Can Be Complicated, But You Don't Have To Navigate It Alone.
        We've Helped Hundreds Of People Overcome These Exact Obstacles
        <span class="tps-cta-banner-accent"> — We Can Do It For You Too.</span>
      </p>
      <a class="btn btn-whatsapp tps-cta-banner-btn" href={brand.whatsappHref} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.8-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.7.2-1.2.2-1.4-.1-.2-.3-.3-.6-.4Zm-5.4 7.5h-.1c-1.8 0-3.6-.5-5.1-1.4l-.4-.2-3.8 1 1-3.7-.2-.4c-1-1.6-1.5-3.4-1.5-5.3 0-5.5 4.5-10 10-10 2.7 0 5.2 1 7 2.9 1.9 1.9 2.9 4.4 2.9 7.1 0 5.5-4.5 10-10 10Zm8.5-18.5C18.3 1 15.3 0 12.1 0 5.4 0 0 5.4 0 12c0 2.1.6 4.2 1.6 6.1L0 24l5.9-1.5c1.8 1 3.9 1.5 6.1 1.5h.1c6.6 0 12-5.4 12-12 0-3.2-1.3-6.2-3.5-8.5Z"/>
        </svg>
        Talk to Us About Your Situation
      </a>
    </div>
  </section>

  <!-- ── Pricing ── -->
  <section class="section tps-pricing-section">
    <div class="container">
      <!-- Flat Fee Guarantee badge -->
      <div class="tps-guarantee-badge">
        <CheckCircle2 size={16} stroke-width={2} />
        <div>
          <strong>Flat Fee Guarantee</strong>
          <span>Our price quote is the price you pay. No surprise bills. No payment plans available.</span>
        </div>
      </div>

      <div class="tps-pricing-head">
        <h2>Affordable TPS Help With <span class="tps-pricing-accent">No Hidden Costs</span></h2>
        <p>Our pricing is transparent and affordable, with flexible payment plans to fit your budget. We also help you request government fee waivers so you can afford paying the filing fees to USCIS. Fee for waiver approval value is over $0.</p>
      </div>

      <!-- 4 pricing cards -->
      <div class="tps-pricing-grid">
        <div class="tps-price-card">
          <h3>Initial TPS Registration</h3>
          <div class="tps-price-amount">$1,500 <span>Attorney Fee</span></div>
          <ul class="tps-price-list">
            <li>Complete eligibility assessment</li>
            <li>Document collection &amp; review</li>
            <li>Form I-821 preparation &amp; filing</li>
            <li>Form I-765 (work permit) included</li>
            <li>Biometrics appointment preparation</li>
            <li>Government fee guidance included</li>
            <li>Case monitoring and updates</li>
            <li>English, Spanish, Creole, French</li>
            <li>Free initial monitoring through approval</li>
          </ul>
        </div>

        <div class="tps-price-card tps-price-card--featured">
          <div class="tps-price-featured-tag">Most Popular</div>
          <h3>TPS Re-Registration</h3>
          <div class="tps-price-amount">$1,200 <span>Attorney Fee</span></div>
          <ul class="tps-price-list">
            <li>Everything in initial package</li>
            <li>TPS re-registration timing &amp; filing</li>
            <li>Advance Parole preparation</li>
            <li>Work permit renewal</li>
            <li>Criminal waivers if applicable</li>
            <li>Document updates &amp; gathering</li>
            <li>Priority status updates</li>
          </ul>
        </div>

        <div class="tps-price-card">
          <h3>Complex TPS Case</h3>
          <div class="tps-price-amount">$2,500–$4,500 <span>Attorney Fee</span></div>
          <ul class="tps-price-list">
            <li>Prior removal order review</li>
            <li>Criminal history analysis</li>
            <li>Advanced documentation building</li>
            <li>Multiple family members</li>
            <li>Appeals &amp; motions included</li>
            <li>RFE response included</li>
            <li>Priority case handling</li>
            <li>Premium support access</li>
          </ul>
        </div>

        <div class="tps-price-card">
          <h3>Family TPS Applications</h3>
          <div class="tps-price-amount">$1,200<span>/per person</span></div>
          <div class="tps-price-sub">$1,500 per attorney</div>
          <ul class="tps-price-list">
            <li>Coordinated scheduling for the whole family</li>
            <li>Bundled document review</li>
            <li>Family discount rates applied</li>
            <li>Single point of contact for all cases</li>
            <li>Simultaneous filing coordination</li>
          </ul>
        </div>
      </div>

      <!-- Add-On Services -->
      <div class="tps-addons">
        <h3>Add-On Services</h3>
        <div class="tps-addons-grid">
          {[
            { name: 'Advance Parole (Travel Permission)', price: '$650' },
            { name: "Driver's License Application Assistance", price: '$150' },
            { name: 'Social Security Card Application', price: '$100' },
            { name: 'Translation Services', price: 'TBD' },
          ].map(({ name, price }) => (
            <div class="tps-addon-card">
              <strong>{name}</strong>
              <span>{price}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Government Fees + Fee Waiver -->
      <div class="tps-fees-grid">
        <div class="tps-gov-fees">
          <h3>Government Fees <em>(If Waiver Denied)</em></h3>
          <ul>
            <li><span>Form I-821 TPS Application</span><strong>$50</strong></li>
            <li><span>Form I-765 Work Permit Application</span><strong>$85</strong></li>
            <li><span>Biometrics Fee</span><strong>$85</strong></li>
            <li class="tps-fees-total"><span>Total Per Person (Inc.)</span><strong>$220</strong></li>
          </ul>
        </div>

        <div class="tps-fee-waiver">
          <div class="tps-fee-waiver-header">
            <CheckCircle2 size={18} stroke-width={2} />
            <strong>Fee Waiver Available!</strong>
          </div>
          <p>If your household income is at or below 150% of the federal poverty line, or you're facing severe financial hardship, you can request USCIS waiver of fees.</p>
          <p class="tps-poverty-label">2024 Income Limits For 150% Poverty Line:</p>
          <ul class="tps-poverty-list">
            <li><span>1 Person</span><strong>$22,590/yr</strong></li>
            <li><span>2 Person</span><strong>$30,600/yr</strong></li>
            <li><span>3 Person</span><strong>$38,610/yr</strong></li>
            <li><span>4 Person</span><strong>$46,620/yr</strong></li>
          </ul>
          <p class="tps-waiver-rate">Our Fee Waiver Approval Rate: <strong>91%+</strong></p>
        </div>
      </div>

      <!-- Payment bar -->
      <div class="tps-payment-bar">
        {[
          'Payment Plans Available',
          'Major Credit Cards',
          'Zelle &amp; Wire Transfer',
          'Secure Online Portal',
        ].map((item) => (
          <span set:html={item} />
        ))}
      </div>
    </div>
  </section>

  <!-- ── Testimonials ── -->
  <section class="section tps-stories-section">
    <div class="container">
      <div class="tps-stories-head">
        <span class="tps-eyebrow">
          <BadgeCheck size={16} stroke-width={1.8} />
          Real Success Stories
          <BadgeCheck size={16} stroke-width={1.8} />
        </span>
        <h2>Protected. Working. Safe.</h2>
        <p>These stories come from real people we've helped secure TPS protection and work authorization — in English, Spanish, and Haitian Creole.</p>
      </div>
      <div class="tps-stories-grid">
        {stories.map((story) => (
          <article class="tps-story-card">
            <Quote class="tps-story-quote" size={34} stroke-width={1.4} />
            <div class="tps-story-stars" aria-label={`${story.stars} out of 5 stars`}>
              {Array.from({ length: 5 }, (_, i) =>
                i < story.stars
                  ? <Star size={15} fill="currentColor" stroke-width={0} />
                  : <Star size={15} stroke-width={1.6} />
              )}
            </div>
            <h3 class="tps-story-title">"{story.title}"</h3>
            <p>{story.text}</p>
            <footer>
              <strong>{story.name}</strong>
              <span>{story.city}</span>
            </footer>
          </article>
        ))}
      </div>
