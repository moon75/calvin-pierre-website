---

<BaseLayout
  title={`Work Visas & Employment Authorization | ${brand.firmName}`}
  description={`H-1B, L-1, O-1, TN, EAD and more — employment-based immigration representation by ${brand.attorneyName}. Strategic work visa planning for professionals and employers.`}
>
  <section class="page-hero section-dark work-hero">
    <div class="container work-hero-content">
      <span class="work-hero-eyebrow">{hero.eyebrow}</span>
      <h1 class="work-hero-headline">
        {hero.title.pre}{' '}
        <span class="work-hero-accent">{hero.title.accent}</span>{' '}
        {hero.title.post}
      </h1>
      <p class="work-hero-lede">{hero.intro}</p>
      <div class="work-hero-actions">
        {hero.actions.map((action) => (
          action.kind === 'whatsapp' ? (
            <a class="btn btn-work-whatsapp" href={action.href} target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.8-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.7.2-1.2.2-1.4-.1-.2-.3-.3-.6-.4Zm-5.4 7.5h-.1c-1.8 0-3.6-.5-5.1-1.4l-.4-.2-3.8 1 1-3.7-.2-.4c-1-1.6-1.5-3.4-1.5-5.3 0-5.5 4.5-10 10-10 2.7 0 5.2 1 7 2.9 1.9 1.9 2.9 4.4 2.9 7.1 0 5.5-4.5 10-10 10Zm8.5-18.5C18.3 1 15.3 0 12.1 0 5.4 0 0 5.4 0 12c0 2.1.6 4.2 1.6 6.1L0 24l5.9-1.5c1.8 1 3.9 1.5 6.1 1.5h.1c6.6 0 12-5.4 12-12 0-3.2-1.3-6.2-3.5-8.5Z"/>
              </svg>
              <span>{action.label}</span>
            </a>
          ) : (
            <a class="btn btn-work-light" href={action.href}>
              <CalendarCheck size={16} stroke-width={2} />
              <span>{action.label}</span>
            </a>
          )
        ))}
      </div>
    </div>
  </section>

  <section class="section section-soft watermark-section">
    <div class="container body-grid">
      <article class="body-article">
        <p class="eyebrow">Practice Area</p>
        <h2>Work Authorization In The U.S.</h2>
        {bodyParagraphs.map((p) => <p>{p}</p>)}
      </article>
      <aside class="key-points">
        <h3>Key Points</h3>
        <ul>
          {keyPoints.map((point) => (
            <li>
              <CheckCircle2 size={18} stroke-width={2} />
              <span>{point}</span>
            </li>
          ))}
        </ul>
        <a class="key-points-cta" href={brand.whatsappHref} target="_blank" rel="noopener">
          Ask About Your Work Visa Options
          <ArrowRight size={14} stroke-width={2} />
        </a>
      </aside>
    </div>
  </section>

  <section class="section path-section">
    <div class="container path-head">
      <span class="hero-eyebrow"><Sparkles size={16} stroke-width={1.8} />Strategic And Streamlined<Sparkles size={16} stroke-width={1.8} /></span>
      <h2>Your Path To Work Authorization</h2>
      <p>Eight purposeful stages — from strategy session to green-card planning — designed to maximize approval odds and prevent authorization gaps.</p>
    </div>
    <div class="container path-list">
      {pathSteps.map((step, index) => (
        <details class="path-step" name="path-steps" open={index === 0}>
          <summary>
            <span class="path-number">{step.number}</span>
            <span class="path-title">{step.title}</span>
            <span class="path-icon" aria-hidden="true"><Plus size={20} stroke-width={1.8} /></span>
          </summary>
          <div class="path-body">
            <p class="path-lead">{step.body}</p>
            <div class="path-roles">
              {step.roles.map((role) => (
                <div class="path-role">
                  <strong>{role.label}</strong>
                  <span>{role.text}</span>
                </div>
              ))}
            </div>
            {step.groups && step.groups.map((group) => (
              <div class="path-group">
                <h4>{group.heading}</h4>
                <ul>
                  {group.items.map((item) => <li>{item}</li>)}
                </ul>
              </div>
            ))}
            {step.note && <p class="path-note">{step.note}</p>}
            <p class="path-timeline"><Clock size={14} stroke-width={2} /> <em>Timeline: {step.timeline}</em></p>
          </div>
        </details>
      ))}
    </div>
  </section>

  <section class="section section-soft watermark-section stories-section">
    <div class="container stories-head">
      <span class="hero-eyebrow"><BadgeCheck size={16} stroke-width={1.8} />Real Success Stories<BadgeCheck size={16} stroke-width={1.8} /></span>
      <h2>Legal Work, Real Lawyers, Real Success Stories</h2>
      <p>Six clients who turned uncertain work authorization into careers, families, and futures in the United States.</p>
    </div>
    <div class="container stories-grid">
      {successStories.map((story) => (
        <article class="story-card">
          <div class="story-tag">{story.category}</div>
          <h3>{story.name}</h3>
          <p class="story-visa">{story.visa}</p>
          <p class="story-quote">&ldquo;{story.quote}&rdquo;</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section challenges-section">
    <div class="container challenges-head">
      <span class="hero-eyebrow"><ShieldCheck size={16} stroke-width={1.8} />Obstacles We Overcome<ShieldCheck size={16} stroke-width={1.8} /></span>
      <h2>Work Visa Obstacles We Help You Overcome</h2>
      <p>{obstaclesIntro}</p>
    </div>
    <div class="container challenges-list">
      {challenges.map((challenge) => (
        <article class="challenge-card">
          <header>
            <span class="challenge-number">Challenge {challenge.number}</span>
            <h3>{challenge.title}</h3>
          </header>
          <div class="challenge-grid">
            <div class="challenge-block">
              <h4>The Problem</h4>
              <p>{challenge.problem.lead}</p>
              <ul>
                {challenge.problem.items.map((item) => <li>{item}</li>)}
              </ul>
            </div>
            <div class="challenge-block">
              <h4>Our Solution</h4>
              <p>{challenge.solution.lead}</p>
              <ul>
                {challenge.solution.items.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </div>
          <div class="challenge-outcome">
            <strong>Outcome:</strong> {challenge.outcome}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-soft watermark-section pricing-section">
    <div class="container pricing-head">
      <span class="hero-eyebrow"><Wallet size={16} stroke-width={1.8} />Transparent Pricing<Wallet size={16} stroke-width={1.8} /></span>
      <h2>Work Visa Cost &amp; Pricing Guide</h2>
      <p>Flat-fee attorney rates by visa category. Government filing fees, premium processing, and third-party costs are listed separately so you know exactly what to budget.</p>
    </div>
    <div class="container pricing-grid">
      {pricingTiers.map((tier) => (
        <article class="pricing-card">
          <header>
            <h3>{tier.name}</h3>
            <div class="pricing-price">
              <span class="pricing-amount">{tier.price}</span>
              <span class="pricing-note">{tier.priceNote}</span>
            </div>
          </header>
          <div class="pricing-section-block">
            <h4>What's Included</h4>
            <ul class="check-list">
              {tier.included.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="pricing-section-block">
            <h4>Not Included</h4>
            <ul class="muted-list">
              {tier.excluded.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <p class="pricing-timeline"><Clock size={14} stroke-width={2} /> {tier.timeline}</p>
          {tier.note && <p class="pricing-note-block">{tier.note}</p>}
        </article>
      ))}
    </div>

    <div class="container addons-block">
      <h3>Add-On Services</h3>
      <div class="addons-grid">
        {addOnServices.map((addon) => (
          <article class="addon-card">
            <h4>{addon.name}</h4>
            <span class="addon-price">{addon.price}</span>
            <p>{addon.body}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="container payment-block">
      <div class="payment-card">
        <h3>Payment Options</h3>
        <ul>
          {paymentOptions.map((option) => (
            <li>
              <CheckCircle2 size={16} stroke-width={2} />
              <span>{option}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="payment-card payment-card--guarantee">
        <h3>Our Guarantee</h3>
        <p>{guarantee}</p>
      </div>
    </div>
  </section>

  <section class="section resources-section">
    <div class="container resources-head">
      <span class="hero-eyebrow"><Lightbulb size={16} stroke-width={1.8} />Career Tools<Lightbulb size={16} stroke-width={1.8} /></span>
      <h2>Free Work Visa Resources &amp; Career Tools</h2>
      <p>Plan smarter with these free tools — but personalized legal strategy is still what protects your career. Don't leave your work authorization to chance.</p>
    </div>
    <div class="container resources-grid">
      {resources.map((resource) => {
        const Icon = resource.Icon;
        return (
          <article class="resource-card">
            <div class="resource-icon"><Icon size={26} stroke-width={1.6} /></div>
            <h3>{resource.title}</h3>
            <p>{resource.body}</p>
            <a class="resource-btn" href="/book-now/">
              {resource.button}
              <ArrowRight size={14} stroke-width={2} />
            </a>
          </article>
        );
      })}
    </div>
    <div class="container resources-cta">
